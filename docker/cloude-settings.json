{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$CLOUDE_ROOT/bin/cloude-on-plan-accepted"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLOUDE_ROOT/bin/cloude-on-user-prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLOUDE_ROOT/bin/cloude-on-stop"
          }
        ]
      }
    ]
  }
}
