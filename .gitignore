# Source clones and worktrees managed by /promote
repos/
worktrees/

# Track project-scoped slash commands and the host-side hook config
# (overrides global ignore of .claude/). settings.local.json and
# anything else under .claude/ stays ignored — those are per-user.
!.claude/
.claude/*
!.claude/commands/
!.claude/settings.json

# Emacs
*~
\#*\#
.\#*
auto-save-list/
.org-id-locations

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc

# Host-side venv built by `make sync` from pyproject.toml + uv.lock.
# Lives outside the container venv (/opt/cloude-venv/) so the cloude
# repo's read-only bind mount doesn't shadow it.
.venv-host/

# User-specific task data — captured per-machine, not part of the repo.
/tasks/staging.org
/tasks/active/*.org
/tasks/completed/*.org
/tasks/dropped/*.org

# Project-specific pre-launch hooks — each user adds their own.
# Exception: repo-hooks/cloude-cade ships with the repo so cloude-self
# development worktrees get the host SessionStart filter automatically.
/repo-hooks/*
!/repo-hooks/.gitkeep
!/repo-hooks/cloude-cade
