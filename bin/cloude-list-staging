#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["orgparse>=0.4"]
# ///
# List promotable ideas from tasks/staging.org for /promote.
#
# staging.org outline shape (vault-rooted):
#
#   * <Vault heading>
#     :PROPERTIES:
#     :SLUG: <vault-slug>          (optional — derived from heading if absent)
#     :END:
#   ** <Project heading>
#      :PROPERTIES:
#      :REPO: https://github.com/...
#      :SKIP_REVIEW: t              (optional)
#      :END:
#   *** <Idea heading>
#       :PROPERTIES:
#       :SLUG: ...                  (optional)
#       :ADOPT: <pr-url>            (optional, ADOPT-mode trigger)
#       :COMPANION: <task-id>       (optional)
#       :END:
#
# Default output (stdout):
#
#   PROMOTABLE
#   1) [<vault-slug>/<project-heading>] idea heading text  [ADOPT]
#   2) [<vault-slug>/<project-heading>] another idea
#   ...
#   TODO_PROJECTS  <count>
#
# Where:
#   - Level-2 headings with a :REPO: property are promotable projects;
#     their level-3 sub-headings are listed (numbered globally so
#     /promote can index by integer).
#   - The vault slug prefix in `[<vault>/<project>]` disambiguates
#     same-named projects across vaults.
#   - [ADOPT] suffix is appended when the idea heading carries an
#     :ADOPT: property in its properties drawer (the ADOPT-mode
#     trigger documented in promote.md). Heading text is free-form
#     in either mode; mode is determined by property presence.
#   - TODO_PROJECTS gives the total count of level-2 headings without
#     :REPO: across all vaults (personal-TODO projects, not
#     promotable). /promote uses it to print the one-line "(TODO-project
#     ideas omitted)" notice without re-parsing the file.
#
# With --select N, instead emits the full record for the idea at
# index N (same numbering as the listing) as shell-safe KEY=VALUE
# lines, so /promote can `eval` it rather than re-parsing staging.org:
#
#   VAULT=<vault-slug>
#   REPO=https://github.com/owner/repo
#   HEADING=<exact idea heading text>
#   MODE=<standard|adopt>
#   PR_URL=<value of the idea's :ADOPT: property, or empty>
#   COMPANION=<value of the idea's :COMPANION: property, or empty>
#   SKIP_REVIEW=<project's :SKIP_REVIEW: property, or empty>
#   SLUG=<value of the idea's :SLUG: property, or empty>
#
# VAULT carries the level-1 vault's resolved slug — its :SLUG: property
# if set, otherwise derive_slug() applied to the heading. /promote
# forwards it to cloude-promote-setup so it lands in the task file's
# :VAULT: property and is used to build vaults/<vault>/{repos,worktrees,
# tasks}/ paths.
#
# SKIP_REVIEW carries the project heading's optional :SKIP_REVIEW:
# property (`t` when the repo opts out of peer review). /promote
# forwards it to cloude-promote-setup so it lands in the task file.
# COMPANION carries the idea's optional :COMPANION: property
# (sibling cloude task ID, slug-dated form); /promote forwards it the
# same way. SLUG carries the idea's optional :SLUG: property — when
# set, cloude-promote uses it as the task slug instead of deriving
# one from the heading. The slug is normally written by the
# staging-slug watcher (`bin/cloude-watch-staging-slugs` /
# `/suggest-slugs`) but can also be hand-edited on the idea drawer.
#
# With --slugless, prints one line per idea sub-heading whose
# properties drawer has no `:SLUG:` (or has an empty `:SLUG:`),
# tab-separated as `<project>\t<heading-text>`. Used by
# `bin/cloude-watch-staging-slugs` to decide when to emit a
# notification line into the host claude session, and by
# `/suggest-slugs` to know which headings need a generated slug.
#
# Exit 0 on success (including empty staging); exit 2 on a usage
# error, an out-of-range --select index, or a file that can't be
# parsed.

from __future__ import annotations

import os
import shlex
import sys
from pathlib import Path

try:
    import orgparse
except ModuleNotFoundError:
    sys.stderr.write(
        "cloude-list-staging: orgparse is required.\n"
        "Launch via 'uv run bin/cloude-list-staging' (uv handles deps),\n"
        "or 'pip install --user orgparse' and rerun.\n"
    )
    sys.exit(2)


# Honor an explicit CLOUDE_ROOT (bin/cloude-run exports this into the
# container) before falling back to the script-location heuristic.
CLOUDE_ROOT = Path(
    os.environ.get("CLOUDE_ROOT") or Path(__file__).resolve().parent.parent
)
STAGING = CLOUDE_ROOT / "tasks" / "staging.org"

# Shared slug-derivation rule for vault headings without :SLUG: — same
# regex /promote applies to ideas, so vault filesystem names follow
# the same shape as idea slugs.
sys.path.insert(0, str(Path(__file__).resolve().parent))
from cloude_org import derive_slug  # noqa: E402


def _collect(root):
    """Walk staging into a list of promotable idea records.

    Returns (records, todo_projects) where each record is a dict with
    keys: index (1-based, global), vault, project, repo, title.
    `todo_projects` is the total count of level-2 (project) headings
    across all vaults that lack a :REPO: property — these are
    personal-TODO projects, surfaced as a single TODO_PROJECTS line so
    /promote can warn about omitted ideas.
    """
    records = []
    todo_projects = 0
    n = 0
    for vault in root.children:
        vault_props = dict(vault.properties) if vault.properties else {}
        vault_heading = str(vault.heading).strip()
        vault_slug = (vault_props.get("SLUG") or "").strip() or derive_slug(
            vault_heading
        )
        for project in vault.children:
            props = dict(project.properties) if project.properties else {}
            if not props.get("REPO"):
                todo_projects += 1
                continue
            project_name = str(project.heading).strip()
            repo = props["REPO"].strip()
            skip_review = (props.get("SKIP_REVIEW") or "").strip()
            for idea in project.children:
                n += 1
                idea_props = dict(idea.properties) if idea.properties else {}
                records.append(
                    {
                        "index": n,
                        "vault": vault_slug,
                        "project": project_name,
                        "repo": repo,
                        "skip_review": skip_review,
                        "title": str(idea.heading).strip(),
                        "adopt_pr": (idea_props.get("ADOPT") or "").strip(),
                        "companion": (idea_props.get("COMPANION") or "").strip(),
                        "slug": (idea_props.get("SLUG") or "").strip(),
                    }
                )
    return records, todo_projects


def _emit(key: str, value: str) -> None:
    print(f"{key}={shlex.quote(value)}")


def main(argv: list[str]) -> int:
    select = None
    slugless = False
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--select":
            i += 1
            if i >= len(argv):
                sys.stderr.write("cloude-list-staging: --select needs an index\n")
                return 2
            try:
                select = int(argv[i])
            except ValueError:
                sys.stderr.write(
                    f"cloude-list-staging: --select index must be an integer, "
                    f"got {argv[i]!r}\n"
                )
                return 2
        elif arg == "--slugless":
            slugless = True
        elif arg in ("-h", "--help"):
            sys.stdout.write(
                "usage: cloude-list-staging [--select N | --slugless]\n"
            )
            return 0
        else:
            sys.stderr.write(f"cloude-list-staging: unexpected argument: {arg}\n")
            return 2
        i += 1

    if select is not None and slugless:
        sys.stderr.write(
            "cloude-list-staging: --select and --slugless are mutually exclusive\n"
        )
        return 2

    if not STAGING.exists():
        if select is not None:
            sys.stderr.write(
                f"cloude-list-staging: no staging file at {STAGING}\n"
            )
            return 2
        if slugless:
            return 0
        print("PROMOTABLE")
        print("TODO_PROJECTS 0")
        return 0
    try:
        root = orgparse.load(str(STAGING))
    except Exception as exc:
        sys.stderr.write(f"cloude-list-staging: failed to parse {STAGING}: {exc}\n")
        return 2

    records, todo_projects = _collect(root)

    if select is not None:
        match = next((r for r in records if r["index"] == select), None)
        if match is None:
            sys.stderr.write(
                f"cloude-list-staging: --select {select} is out of range "
                f"(1..{len(records)})\n"
            )
            return 2
        adopt_pr = match["adopt_pr"]
        is_adopt = bool(adopt_pr)
        _emit("VAULT", match["vault"])
        _emit("REPO", match["repo"])
        _emit("HEADING", match["title"])
        _emit("MODE", "adopt" if is_adopt else "standard")
        _emit("PR_URL", adopt_pr)
        _emit("COMPANION", match["companion"])
        _emit("SKIP_REVIEW", match["skip_review"])
        _emit("SLUG", match["slug"])
        return 0

    if slugless:
        for r in records:
            if not r["slug"]:
                print(f"{r['project']}\t{r['title']}")
        return 0

    print("PROMOTABLE")
    for r in records:
        suffix = "  [ADOPT]" if r["adopt_pr"] else ""
        print(
            f"{r['index']}) [{r['vault']}/{r['project']}] {r['title']}{suffix}"
        )
    print(f"TODO_PROJECTS {todo_projects}")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
