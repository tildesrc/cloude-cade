#!/usr/bin/env python3
"""Stop hook handler — keep the heading tag honest, check the DoD sparingly.

Fires at the end of every agent turn. It does two distinct jobs, and
the split between them is the whole point of this hook:

1. Deterministic tag maintenance. When a turn ends with the task in
   PLANNING or ITERATING still tagged `:agent:`, the agent has handed
   the ball back, so the tag is flipped to `:user:`. This is
   mechanical — the agent never retags by hand — and it is the
   end-of-turn counterpart to `cloude-on-user-prompt`'s start-of-turn
   `:user:` -> `:agent:` flip. `:blocked:` is never touched (a
   deliberate state the agent may set to keep the ball off the user);
   MERGING is never touched (agent-driven — `/babysit-merge` owns it).

2. A Definition-of-Done reminder, but only at the end of a turn that
   began with a stage transition or an `/iterate`. Those turns drop a
   marker file (see `cloude_org.dod_marker_path`); this hook consumes
   the marker and, only then, blocks the stop once to inject the
   current stage's DoD checklist. An ordinary conversational turn
   drops no marker, so it gets no block and no reminder text crowding
   out the agent's actual answer.

If an autonomous babysit loop (`/babysit-ci` or `/babysit-merge`) is
running — detected by its state file in the worktree — this hook does
nothing at all: that loop owns the heading for its whole duration.

The single-block-per-stop guarantee comes from honoring the harness's
`stop_hook_active` flag: when set, the DoD reminder is skipped, so the
model cannot get stuck in a block loop.

Everything else is a silent no-op (no task file, unparseable heading,
a terminal COMPLETE / DROPPED stage, an active babysit loop).

Why this exists: `bin/cloude-dash` color-codes every active task by
`:agent:` / `:user:` / `:blocked:`. A stale `:agent:` silently lies to
the dashboard and hides a task that actually needs user attention —
job 1 keeps that honest without nagging the agent on every turn.

Registered via /etc/cloude/settings.json, which bin/cloude-run wires
in by passing `--settings /etc/cloude/settings.json` to claude.

The DoD bullets below mirror CLAUDE.md's `#### <STAGE>` sections
("Stage details"). If you edit one, edit the other.
"""

import json
import os
import subprocess
import sys
from pathlib import Path

# The heading parser and the marker-path helper are shared with the
# sibling hook scripts; all run on plain stdlib python3, so they live
# in `cloude_org.py` rather than orgparse (see that module for the
# full rationale).
sys.path.insert(0, str(Path(__file__).resolve().parent))
from cloude_org import ball_tag, dod_marker_path, parse_heading  # noqa: E402

# In-flight stages — the terminal COMPLETE / DROPPED states get neither
# a tag flip nor a DoD reminder.
IN_FLIGHT = ("PLANNING", "ITERATING", "REVIEW", "MERGING")

# Stages whose `:agent:` tag is flipped to `:user:` at end of turn.
# REVIEW sits at `:blocked:` by default and MERGING is agent-driven
# (`/babysit-merge` owns its tag), so neither is auto-handed-back.
AUTO_HANDBACK = ("PLANNING", "ITERATING")

# Babysit-loop state files, relative to the worktree. The skills create
# them on start and delete them on clean exit / bail; their presence
# means an autonomous loop owns the heading and this hook stays out.
BABYSIT_STATE_FILES = (
    ".cloude-babysit-state.json",
    ".cloude-babysit-merge-state.json",
)


DOD = {
    "PLANNING": [
        "The plan is written into the task's org file.",
        "The user has approved the plan.",
        "A draft PR has been created on GitHub.",
    ],
    "ITERATING": [
        "The plan is implemented in code.",
        "All user requests are implemented in code.",
        "New and relevant tests pass locally.",
        "Changes are committed and pushed.",
        "CI tests are passing, or any failures can be attributed to irrelevant flakes.",
        "The PR title and description on GitHub reflect the final change (not the draft-PR placeholder).",
    ],
    "REVIEW": [
        "The PR has been reviewed.",
    ],
    "MERGING": [
        "The PR is merged.",
    ],
}


def main() -> int:
    try:
        hook_input = json.load(sys.stdin)
    except (ValueError, AttributeError):
        hook_input = {}

    task = os.environ.get("CLOUDE_TASK_FILE")
    if not task or not Path(task).is_file():
        return 0

    parsed = parse_heading(Path(task).read_text())
    if parsed is None:
        return 0

    state, tags = parsed
    if state not in IN_FLIGHT:
        return 0  # terminal stage — nothing to maintain

    # An autonomous babysit loop owns the heading while it runs; don't
    # flip the tag or block the stop out from under it.
    if babysit_loop_active(hook_input.get("cwd")):
        return 0

    # The marker pertains only to the turn that just ended; consume it
    # now (read-then-unlink) so it can never linger into a later turn.
    marker = dod_marker_path(task)
    marker_armed = marker.exists()
    marker.unlink(missing_ok=True)

    ball = ball_tag(tags)

    # DoD reminder: only when this turn began with a transition /
    # `/iterate` (marker armed), only while the agent still holds the
    # ball, and only once per stop cycle (honor `stop_hook_active`).
    if (
        marker_armed
        and ball == "agent"
        and state in DOD
        and not hook_input.get("stop_hook_active")
    ):
        print(json.dumps({"decision": "block", "reason": build_reason(state)}))
        return 0

    # Deterministic hand-back: the agent stopped holding the ball in a
    # user-driven stage, so flip it to `:user:` for the dashboard.
    if ball == "agent" and state in AUTO_HANDBACK:
        flip_to_user(task)
    return 0


def babysit_loop_active(cwd: str | None) -> bool:
    """True when a `/babysit-ci` or `/babysit-merge` loop is running.

    Detected by the state file the skills keep in the worktree (created
    on start, deleted on clean exit / bail). `cwd` is the Stop hook
    input's working directory — the in-container `claude` runs in the
    task worktree, so the state files sit directly under it. A missing
    `cwd` just means we can't tell; treat that as "not active".
    """
    if not cwd:
        return False
    return any((Path(cwd) / name).is_file() for name in BABYSIT_STATE_FILES)


def flip_to_user(task: str) -> None:
    """Flip the heading tag to `:user:` via the shared set-state helper.

    Keeps the structural heading rewrite in `cloude-task-set-state`, its
    one canonical home. Passing only `--tag` leaves the TODO keyword and
    heading text untouched (and drops no DoD marker — only a `--todo`
    transition does that). A failed flip is warned to stderr and
    otherwise ignored: it must never block the stop.
    """
    helper = Path(__file__).resolve().with_name("cloude-task-set-state")
    try:
        subprocess.run(
            [sys.executable, str(helper), task, "--tag", "user"],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError) as exc:
        detail = getattr(exc, "stderr", "") or str(exc)
        sys.stderr.write(f"cloude-on-stop: tag flip failed: {detail}\n")


def build_reason(state: str) -> str:
    """The DoD reminder injected once at the end of a transition turn."""
    bullets = "\n".join(f"  - {b}" for b in DOD[state])

    if state == "MERGING":
        tail = (
            "MERGING is agent-driven: invoke `/babysit-merge` to drive the\n"
            "merge queue through to a landed PR. That skill owns the\n"
            "heading tag for the MERGING stage — not this hook."
        )
    else:
        tail = (
            f"If `{state}`'s work isn't finished, keep going. If it is,\n"
            f"just stop — this hook hands the ball back to the user for\n"
            f"you, so you don't need to retag the heading by hand. To\n"
            f"keep the ball off the user (waiting on something external),\n"
            f"set the heading tag to `:blocked:` yourself."
        )

    return (
        f"This turn began with a transition into `{state}` (or an "
        f"`/iterate`).\n"
        f"Before it ends, walk through `{state}`'s Definition of Done:\n"
        f"{bullets}\n"
        f"\n"
        f"{tail}\n"
        f"\n"
        f"(This DoD reminder fires once per stop cycle, and only on\n"
        f"transition / `/iterate` turns — never on an ordinary turn.)"
    )


if __name__ == "__main__":
    sys.exit(main())
