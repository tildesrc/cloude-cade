#!/usr/bin/env python3
"""Stop hook handler — keep the heading tag honest, check the DoD sparingly.

Fires at the end of every agent turn. It does two distinct jobs, and
the split between them is the whole point of this hook:

1. Deterministic tag maintenance. When a turn ends with the task in
   PLANNING or ITERATING still tagged `:agent:`, the agent has handed
   the ball back, so the tag is flipped to `:user:`. This is
   mechanical — the agent never retags by hand — and it is the
   end-of-turn counterpart to `cloude-on-user-prompt`'s start-of-turn
   `:user:` -> `:agent:` flip. `:blocked:` is never touched (a
   deliberate state the agent may set to keep the ball off the user);
   MERGING is never touched (agent-driven — `/babysit-merge` owns it).

2. A Definition-of-Done check, but only at the end of a turn that
   began with a stage transition or an `/iterate`. Those turns drop a
   marker file (see `cloude_org.dod_marker_path`); this hook consumes
   the marker and, only then, inspects the latest `*** ` entry in the
   task file's `** Log` section. The verdict is the TODO keyword on
   that entry's `**** DoD` sub-sub-heading (drawn from the secondary
   `#+TODO:` sequence — PENDING / UNSATISFIABLE / PASS), and the
   per-bullet checkboxes inside the DoD body must agree with it
   (PASS requires every box ticked or N/A; UNSATISFIABLE requires at
   least one open). The hook blocks only when the verdict is PENDING,
   the cookie/verdict are inconsistent, or the schema is broken
   (missing `** Log`, missing latest entry, stage mismatch). On every
   happy path the hook stays silent — the agent's organic end-of-turn
   message remains the visible last content.

If the agent ends a turn while still waiting on background work, this
hook is a full no-op — no tag flip, no DoD reminder, and the DoD
marker (if armed) is preserved for the next turn so the reminder
eventually fires once the background work settles. Two signals each
suffice to keep the hook silent:

- A `/babysit-ci` or `/babysit-merge` state file in the worktree (the
  skills' own positive marker — they also use these files for their
  own persistent state, so they stay).
- An in-flight background Bash detected by scanning the transcript:
  any assistant `tool_use` for Bash with `run_in_background: true`
  whose completion `task-notification` (delivered as a
  `queue-operation` enqueue) hasn't arrived yet.

This generalizes the babysit carve-out to every background Bash the
agent kicks off, so the dashboard accurately shows `:agent:` while
the agent is genuinely waiting on work it owns.

The single-block-per-stop guarantee comes from honoring the harness's
`stop_hook_active` flag: when set, the DoD check is skipped, so the
model cannot get stuck in a block loop.

Everything else is a silent no-op (no task file, unparseable heading,
a terminal COMPLETE / DROPPED stage, a babysit loop active, or an
in-flight background Bash).

Why this exists: `bin/cloude-dash` color-codes every active task by
`:agent:` / `:user:` / `:blocked:`. A stale `:agent:` silently lies to
the dashboard and hides a task that actually needs user attention —
job 1 keeps that honest without nagging the agent on every turn.

Registered via /etc/cloude/settings.json, which bin/cloude-run wires
in by passing `--settings /etc/cloude/settings.json` to claude.

The per-stage DoD bullets live in `cloude_org.STAGE_DOD` (the same
module that defines the log-entry schema and the verdict-flip helper).
`CLAUDE.md`'s `#### <STAGE>` sections mirror those bullets as the
human-facing copy; if you edit one, edit the other.
"""

import json
import os
import re
import subprocess
import sys
from pathlib import Path

# The heading parser and the marker-path helper are shared with the
# sibling hook scripts; all run on plain stdlib python3, so they live
# in `cloude_org.py` rather than orgparse (see that module for the
# full rationale).
sys.path.insert(0, str(Path(__file__).resolve().parent))
from cloude_org import (  # noqa: E402
    ball_tag,
    dod_marker_path,
    find_log_section,
    latest_log_entry,
    parse_heading,
)

# In-flight stages — the terminal COMPLETE / DROPPED states get neither
# a tag flip nor a DoD reminder.
IN_FLIGHT = ("PLANNING", "ITERATING", "REVIEW", "MERGING")

# Stages whose `:agent:` tag is flipped to `:user:` at end of turn.
# REVIEW sits at `:blocked:` by default and MERGING is agent-driven
# (`/babysit-merge` owns its tag), so neither is auto-handed-back.
AUTO_HANDBACK = ("PLANNING", "ITERATING")

# Babysit-loop state files, relative to the worktree. The skills create
# them on start and delete them on clean exit / bail; their presence
# means an autonomous loop owns the heading and this hook stays out.
BABYSIT_STATE_FILES = (
    ".cloude-babysit-state.json",
    ".cloude-babysit-merge-state.json",
)


def main() -> int:
    try:
        hook_input = json.load(sys.stdin)
    except (ValueError, AttributeError):
        hook_input = {}

    task = os.environ.get("CLOUDE_TASK_FILE")
    if not task or not Path(task).is_file():
        return 0

    content = Path(task).read_text()
    parsed = parse_heading(content)
    if parsed is None:
        return 0

    state, tags = parsed
    if state not in IN_FLIGHT:
        return 0  # terminal stage — nothing to maintain

    # An autonomous babysit loop or an in-flight background Bash means
    # the agent is still actively waiting on work it owns. Stay silent:
    # don't flip the tag, don't consume the DoD marker (so a transition
    # turn that ended with background work pending still gets its DoD
    # check once the background work finally settles).
    if should_stay_silent(hook_input):
        return 0

    # The marker pertains only to the turn that just ended; consume it
    # now (read-then-unlink) so it can never linger into a later turn.
    marker = dod_marker_path(task)
    marker_armed = marker.exists()
    marker.unlink(missing_ok=True)

    ball = ball_tag(tags)

    # DoD check: only when this turn began with a transition /
    # `/iterate` (marker armed), only while the agent still holds the
    # ball, and only once per stop cycle (honor `stop_hook_active`).
    if (
        marker_armed
        and ball == "agent"
        and not hook_input.get("stop_hook_active")
    ):
        reason = check_dod(content, state)
        if reason is not None:
            print(json.dumps({"decision": "block", "reason": reason}))
            return 0

    # Deterministic hand-back: the agent stopped holding the ball in a
    # user-driven stage, so flip it to `:user:` for the dashboard.
    if ball == "agent" and state in AUTO_HANDBACK:
        flip_to_user(task)
    return 0


def check_dod(content: str, state: str) -> str | None:
    """Inspect the latest log entry for the current stage; return a
    block reason if the DoD is not satisfied (or absent / malformed),
    or None to stay silent.
    """
    if find_log_section(content) is None:
        return build_missing_log_reason()
    entry = latest_log_entry(content)
    if entry is None:
        return build_empty_log_reason(state)
    if entry["stage"] != state:
        return build_schema_mismatch_reason(entry["stage"], state)
    verdict = entry["dod_verdict"]
    boxes = entry["dod_checkboxes"]
    n_open = sum(1 for c in boxes if c == "open")
    n_total = len(boxes)
    if verdict == "PENDING":
        return build_pending_dod_reason(state)
    if verdict == "PASS" and n_open > 0:
        return build_pass_mismatch_reason(state, n_open, n_total)
    if verdict == "UNSATISFIABLE" and n_total > 0 and n_open == 0:
        return build_unsat_mismatch_reason(state)
    return None


def should_stay_silent(hook_input: dict) -> bool:
    """True when the hook must be a full no-op for this Stop.

    Two independent signals — either one is sufficient:
      1. A `/babysit-ci` or `/babysit-merge` state file in `cwd`. The
         skills keep these as their own positive markers (and use them
         for their own persistent state — `watch_bash_id`, retry
         counts, etc.). Their presence means an autonomous loop owns
         the heading for the duration of the loop.
      2. The transcript records at least one Bash `run_in_background`
         start without a matching completion `task-notification`. This
         generalizes the carve-out: any background Bash the agent kicks
         off keeps the heading at `:agent:` while it's still running.
    """
    return (
        babysit_loop_active(hook_input.get("cwd"))
        or background_bash_pending(hook_input.get("transcript_path"))
    )


def babysit_loop_active(cwd: str | None) -> bool:
    """True when a `/babysit-ci` or `/babysit-merge` loop is running.

    Detected by the state file the skills keep in the worktree (created
    on start, deleted on clean exit / bail). `cwd` is the Stop hook
    input's working directory — the in-container `claude` runs in the
    task worktree, so the state files sit directly under it. A missing
    `cwd` just means we can't tell; treat that as "not active".
    """
    if not cwd:
        return False
    return any((Path(cwd) / name).is_file() for name in BABYSIT_STATE_FILES)


# Compiled once at import time — both regexes apply to every queue-operation
# enqueue entry whose content carries a `<task-notification>` block.
_TASK_TUID_RE = re.compile(r"<tool-use-id>([^<]+)</tool-use-id>")
_TASK_STATUS_RE = re.compile(r"<status>([^<]+)</status>")

# Terminal statuses for a background task — `running` would mean the
# notification is just an interim update (the harness emits those for
# certain tool types, though Bash uses the terminal ones).
_TERMINAL_STATUSES = frozenset(("completed", "killed", "failed"))


def background_bash_pending(transcript_path: str | None) -> bool:
    """True when the transcript records a background Bash whose
    completion notification hasn't arrived yet.

    The Stop hook input from Claude Code includes `transcript_path` (a
    JSONL file). Two kinds of entries get scanned, by tool_use_id:

      - assistant tool_use blocks with `name == "Bash"` and
        `input.run_in_background == true` — these are *starts*.
      - `queue-operation` enqueue entries whose content carries a
        `<task-notification>` block matching one of the started
        tool_use_ids with a terminal `<status>` — these are *finishes*.

    Pending = (starts) − (finishes). A missing or unreadable transcript
    is treated as "no pending tasks" — better to err on the side of
    flipping the tag (today's behavior) than to wedge `:agent:` on a
    bad path.
    """
    if not transcript_path:
        return False
    path = Path(transcript_path)
    if not path.is_file():
        return False
    started: set[str] = set()
    completed: set[str] = set()
    try:
        with path.open(encoding="utf-8", errors="replace") as fh:
            for raw in fh:
                try:
                    entry = json.loads(raw)
                except ValueError:
                    continue
                msg = entry.get("message") or {}
                if msg.get("role") == "assistant":
                    for block in msg.get("content") or []:
                        if not isinstance(block, dict):
                            continue
                        if (
                            block.get("type") == "tool_use"
                            and block.get("name") == "Bash"
                            and (block.get("input") or {}).get("run_in_background")
                        ):
                            tuid = block.get("id")
                            if tuid:
                                started.add(tuid)
                if (
                    entry.get("type") == "queue-operation"
                    and entry.get("operation") == "enqueue"
                ):
                    content = entry.get("content")
                    if isinstance(content, str) and "<task-notification>" in content:
                        m_tuid = _TASK_TUID_RE.search(content)
                        m_status = _TASK_STATUS_RE.search(content)
                        if (
                            m_tuid
                            and m_status
                            and m_status.group(1) in _TERMINAL_STATUSES
                        ):
                            completed.add(m_tuid.group(1))
    except OSError:
        return False
    return bool(started - completed)


def flip_to_user(task: str) -> None:
    """Flip the heading tag to `:user:` via the shared set-state helper.

    Keeps the structural heading rewrite in `cloude-task-set-state`, its
    one canonical home. Passing only `--tag` leaves the TODO keyword and
    heading text untouched (and drops no DoD marker — only a `--todo`
    transition does that). A failed flip is warned to stderr and
    otherwise ignored: it must never block the stop.
    """
    helper = Path(__file__).resolve().with_name("cloude-task-set-state")
    try:
        subprocess.run(
            [sys.executable, str(helper), task, "--tag", "user"],
            check=True,
            capture_output=True,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError) as exc:
        detail = getattr(exc, "stderr", "") or str(exc)
        sys.stderr.write(f"cloude-on-stop: tag flip failed: {detail}\n")


_FLIP_HINT = (
    "Flip the verdict with:\n"
    "  cloude-task-set-state $CLOUDE_TASK_FILE --dod-state {pass|unsatisfiable}\n"
    "  (use --reason \"...\" to record an UNSATISFIABLE explanation)\n"
    "The command refuses inconsistent flips: PASS requires every\n"
    "checkbox ticked (`[X]`) or N/A (`[-]`); UNSATISFIABLE requires at\n"
    "least one open (`[ ]`) box. Tick the boxes by hand-editing the\n"
    "DoD body before running the flip."
)


def build_pending_dod_reason(state: str) -> str:
    """The verdict is still PENDING at the end of a transition turn."""
    return (
        f"The latest `*** ` entry in your task file's `** Log` section is "
        f"for stage `{state}`, and its `**** DoD` sub-sub-heading is "
        f"still `PENDING`. Before this turn ends:\n"
        f"\n"
        f"  - Fill in `**** Request` (a paraphrase of what the user "
        f"asked for this stage).\n"
        f"  - Fill in `**** Work` (what you've done so far — will be "
        f"updated over the stage's lifetime).\n"
        f"  - For each `- [ ]` bullet under `**** DoD`, mark it `[X]` "
        f"(met), `[-]` (N/A), or leave it `[ ]` (unmet).\n"
        f"  - Run the flip:\n"
        f"\n"
        f"{_FLIP_HINT}\n"
        f"\n"
        f"The per-stage DoD bullets you're verifying live in CLAUDE.md "
        f"→ Stage details → `{state}` → Definition of done (mirrored as "
        f"the checkbox text under `**** DoD`).\n"
        f"\n"
        f"This check fires once per stop cycle, and only on transition "
        f"/ `/iterate` turns — never on an ordinary turn. Once the "
        f"verdict is PASS or UNSATISFIABLE, the hook stays out of your "
        f"way."
    )


def build_pass_mismatch_reason(state: str, n_open: int, n_total: int) -> str:
    """Verdict is PASS but boxes are still open — inconsistent."""
    return (
        f"The latest `*** {state}` log entry's verdict is `PASS`, but "
        f"{n_open} of {n_total} DoD checkboxes are still `[ ]` "
        f"(unchecked). PASS requires every box to be `[X]` or `[-]`.\n"
        f"\n"
        f"Either:\n"
        f"  - Tick the remaining boxes (and re-flip if needed), or\n"
        f"  - Flip to UNSATISFIABLE with an explanation:\n"
        f"      cloude-task-set-state $CLOUDE_TASK_FILE \\\n"
        f"          --dod-state unsatisfiable --reason \"...\""
    )


def build_unsat_mismatch_reason(state: str) -> str:
    """Verdict is UNSATISFIABLE but every box is ticked — inconsistent."""
    return (
        f"The latest `*** {state}` log entry's verdict is "
        f"`UNSATISFIABLE`, but every DoD checkbox is ticked or N/A. "
        f"UNSATISFIABLE requires at least one open `[ ]` box "
        f"(documenting what *can't* be met).\n"
        f"\n"
        f"If every bullet is genuinely met, flip to PASS:\n"
        f"  cloude-task-set-state $CLOUDE_TASK_FILE --dod-state pass"
    )


def build_missing_log_reason() -> str:
    """No `** Log` section in the task file — schema not migrated."""
    return (
        "This task file has no `** Log` section. The DoD workflow now "
        "tracks per-stage state in structured log entries; the file "
        "needs to be migrated by hand.\n"
        "\n"
        "Add a `** Log` heading near the bottom of the file (before "
        "any `# Local Variables:` block) and, for the *current* stage, "
        "append an entry skeleton with the shape:\n"
        "\n"
        "  *** [<now>] <STAGE> (via /promote)\n"
        "      :PROPERTIES:\n"
        "      :STAGE:       <STAGE>\n"
        "      :ENTERED:     [<now>]\n"
        "      :ENTERED_VIA: /promote\n"
        "      :END:\n"
        "  **** Request\n"
        "  **** Work\n"
        "  **** [/] PENDING DoD\n"
        "       - [ ] (one bullet per CLAUDE.md DoD criterion for "
        "<STAGE>)\n"
        "\n"
        "Also add a second `#+TODO:` directive near the top of the "
        "file so the verdict keyword renders correctly:\n"
        "  #+TODO: PENDING(P!) UNSATISFIABLE(U!) | PASS(D!)\n"
        "\n"
        "Then re-run the transition that triggered this check."
    )


def build_empty_log_reason(state: str) -> str:
    """`** Log` section exists but has no entries."""
    return (
        f"This task's `** Log` section has no `*** ` entries, but the "
        f"current stage is `{state}`. Add an entry skeleton for "
        f"`{state}` (see CLAUDE.md → Per-stage log entry for the "
        f"shape) and re-run."
    )


def build_schema_mismatch_reason(latest_stage: str, current_state: str) -> str:
    """Latest log entry's :STAGE: doesn't match the level-1 TODO keyword."""
    return (
        f"Schema mismatch: the level-1 heading's TODO keyword is "
        f"`{current_state}`, but the latest `** Log` entry's "
        f"`:STAGE:` property is `{latest_stage}`. This usually means "
        f"the slash command that flipped the stage didn't append a "
        f"fresh log-entry skeleton — likely a bug.\n"
        f"\n"
        f"To recover by hand: append a new `*** [<now>] {current_state} "
        f"(via /...)` entry under `** Log` (mirroring the existing "
        f"entries' shape) and re-run the transition."
    )


if __name__ == "__main__":
    sys.exit(main())
