#!/usr/bin/env python3
"""Rewrite the first heading of a cloude task .org file in place.

Flips the TODO keyword and/or the who-has-the-ball tag without the
caller having to re-derive the org heading regex. Used by the
/advance, /iterate, /drop, /babysit-ci and /babysit-merge skills and
by bin/cloude-finalize-cleanup, so the structural edit of a task
heading lives in exactly one place.

Usage:
    cloude-task-set-state <task-file> [--todo NAME] [--tag NAME]

At least one of --todo / --tag must be given:
  --todo NAME   replace the TODO keyword (must be a known keyword).
  --tag  NAME   replace the entire trailing tag chain with a single
                :NAME: tag.
An omitted flag leaves that part of the heading unchanged. The heading
text and everything below the heading are always preserved.

On success, prints the resulting state as shell-safe KEY=VALUE lines:
    TODO=ITERATING
    TAG=agent
(TAG is empty when the heading carries no who-has-the-ball tag.)

Exit codes:
    0   success
    2   file not found, or no task heading found
    30  argument validation (no flags, unknown TODO keyword, bad tag)

This script edits org text with a single regex rather than orgparse:
orgparse exposes no node byte/line ranges to write back through, and
the heading grammar this touches is small and fixed. It needs no
third-party dependency, so it runs on plain python3.
"""

from __future__ import annotations

import re
import shlex
import sys
from pathlib import Path

# The valid TODO keywords and who-has-the-ball tags come from the
# workflow definition (bin/cloude_workflow.py, a stdlib-only sibling)
# rather than being hardcoded here.
sys.path.insert(0, str(Path(__file__).resolve().parent))
import cloude_workflow  # noqa: E402

_WORKFLOW = cloude_workflow.load()
TODO_KEYWORDS = tuple(_WORKFLOW.state_names)
BALL_TAGS = _WORKFLOW.ball_tag_names

# The first heading of a task file: leading stars + space, a known
# TODO keyword, optional heading text, an optional trailing :tag:chain:,
# then the line end. `.` excludes newlines (no re.S) so `text` stays on
# the heading's own line.
HEADING_RE = re.compile(
    r"^(?P<stars>\*+[ \t]+)"
    r"(?P<todo>" + "|".join(TODO_KEYWORDS) + r")"
    r"(?P<text>[ \t]+\S.*?)?"
    r"[ \t]*"
    r"(?P<tags>:[A-Za-z0-9_@:]+:)?"
    r"[ \t]*"
    r"(?P<nl>\r?\n)",
    re.M,
)


def _ball_tag(tag_chain: str) -> str:
    """Return the who-has-the-ball tag from a `:a:b:` chain, or ''."""
    parts = [p for p in (tag_chain or "").split(":") if p]
    for t in BALL_TAGS:
        if t in parts:
            return t
    return ""


def main(argv: list[str]) -> int:
    task_file: str | None = None
    new_todo: str | None = None
    new_tag: str | None = None

    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--todo":
            i += 1
            if i >= len(argv):
                sys.stderr.write("cloude-task-set-state: --todo needs a value\n")
                return 30
            new_todo = argv[i]
        elif arg == "--tag":
            i += 1
            if i >= len(argv):
                sys.stderr.write("cloude-task-set-state: --tag needs a value\n")
                return 30
            new_tag = argv[i]
        elif arg in ("-h", "--help"):
            sys.stdout.write(__doc__ or "")
            return 0
        elif arg.startswith("-"):
            sys.stderr.write(f"cloude-task-set-state: unknown flag: {arg}\n")
            return 30
        elif task_file is None:
            task_file = arg
        else:
            sys.stderr.write(f"cloude-task-set-state: extra argument: {arg}\n")
            return 30
        i += 1

    if task_file is None:
        sys.stderr.write(
            "usage: cloude-task-set-state <task-file> [--todo NAME] [--tag NAME]\n"
        )
        return 30
    if new_todo is None and new_tag is None:
        sys.stderr.write(
            "cloude-task-set-state: nothing to do — pass --todo and/or --tag\n"
        )
        return 30
    if new_todo is not None and new_todo not in TODO_KEYWORDS:
        sys.stderr.write(
            f"cloude-task-set-state: unknown TODO keyword: {new_todo}\n"
            f"  expected one of: {', '.join(TODO_KEYWORDS)}\n"
        )
        return 30
    if new_tag is not None and not re.fullmatch(r"[A-Za-z0-9_@]+", new_tag):
        sys.stderr.write(
            f"cloude-task-set-state: invalid tag: {new_tag!r} "
            "(letters, digits, '_' and '@' only)\n"
        )
        return 30

    path = Path(task_file)
    if not path.is_file():
        sys.stderr.write(f"cloude-task-set-state: file not found: {path}\n")
        return 2

    content = path.read_text()
    match = HEADING_RE.search(content)
    if not match:
        sys.stderr.write(
            f"cloude-task-set-state: no task heading found in {path}\n"
        )
        return 2

    todo = new_todo if new_todo is not None else match["todo"]
    if new_tag is not None:
        tag_chain = f":{new_tag}:"
    else:
        tag_chain = match["tags"] or ""
    text = (match["text"] or "").strip()

    # Reassemble the heading: a single space separates keyword, text and
    # tag. Alignment padding (if the source used any) is dropped — the
    # active task files don't use it.
    line = match["stars"].rstrip() + " " + todo
    if text:
        line += " " + text
    if tag_chain:
        line += " " + tag_chain
    line += match["nl"]

    content = content[: match.start()] + line + content[match.end() :]
    path.write_text(content)

    print(f"TODO={shlex.quote(todo)}")
    print(f"TAG={shlex.quote(_ball_tag(tag_chain))}")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
