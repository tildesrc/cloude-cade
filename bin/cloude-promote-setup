#!/usr/bin/env bash
# Mechanical setup chain for /promote.
#
# Given an idea already picked from tasks/staging.org and a confirmed
# slug, this performs steps 4-9 of promote.md as one atomic chain:
#
#   1. Derive owner/repo-name/HTTPS-clone-url from --repo-url.
#   2. Ensure the source clone exists at <cloude-root>/repos/<repo>
#      with HTTPS origin + the gh credential helper.
#   3. Create the worktree + feature branch:
#        - standard: cloude/<slug> off origin/<default-branch>, push -u.
#        - adopt:    track origin/<head-ref>, no push.
#   4. (standard only) `gh pr create --draft`. Capture PR URL.
#   5. Render the task file from tasks/TEMPLATE.org with the right
#      properties / TODO keyword / tag for the mode.
#   6. Remove the chosen sub-heading + body from tasks/staging.org.
#   7. Create the detached tmux session with two windows: window 0
#      (`agent`) runs bin/cloude-run; window 1 (`task`) runs
#      bin/cloude-open-task-file as a read-only live view of the
#      task .org file. The `agent` window is left selected.
#   8. Print a summary block on stdout.
#
# Exit codes:
#   0   success
#  10   source clone setup failed
#  11   worktree creation failed
#  12   gh pr create failed (standard only)
#  13   task-file render failed
#  14   staging entry not found / removal failed
#  20   tmux session name already exists
#  30   argument validation failed
#
# On any non-zero exit the stderr message names which steps succeeded
# so the user knows what manual cleanup, if any, is needed.

set -euo pipefail

usage() {
    cat <<EOF
Usage: $(basename "$0") --mode {standard|adopt} <args>

Common required args:
  --mode {standard|adopt}
  --vault <vault-slug>           identifies the vault this task belongs to;
                                 rooted-paths and credential isolation hang
                                 off this. Lands in the task file's :VAULT:
                                 property.
  --slug <slug>                  filesystem-safe slug
  --repo-url <url>               https:// or git@ form, from staging :REPO:
  --task-file <abs-path>         vaults/<vault>/tasks/active/<YYYY-MM-DD>-<slug>.org
  --staging-heading <text>       exact heading to delete from staging.org

Common optional args:
  --skip-review                  repo opts out of peer review; render
                                 :SKIP_REVIEW: t into the task file
  --companion <id>               sibling cloude task ID (slug-dated form);
                                 render :COMPANION: <id> into the
                                 task file's properties drawer

Common args (both modes):
  --heading <text>               idea heading (becomes the task title and,
                                 in standard mode, the planning prompt)

Standard-mode args:
  --default-branch <branch>      base branch for the new PR

ADOPT-mode args:
  --head-ref <ref>               existing PR's branch
  --base-ref <ref>               existing PR's base branch
  --pr-url <url>
  --pr-number <n>
EOF
}

# --- arg parsing -----------------------------------------------------------

MODE=""
VAULT=""
SLUG=""
REPO_URL=""
TASK_FILE=""
STAGING_HEADING=""
HEADING=""
DEFAULT_BRANCH=""
HEAD_REF=""
BASE_REF=""
PR_URL=""
PR_NUMBER=""
SKIP_REVIEW=""
COMPANION=""

if [[ $# -eq 0 ]]; then
    usage >&2
    exit 30
fi

while (($#)); do
    case "$1" in
        --mode)              MODE="$2"; shift 2 ;;
        --vault)             VAULT="$2"; shift 2 ;;
        --slug)              SLUG="$2"; shift 2 ;;
        --repo-url)          REPO_URL="$2"; shift 2 ;;
        --task-file)         TASK_FILE="$2"; shift 2 ;;
        --staging-heading)   STAGING_HEADING="$2"; shift 2 ;;
        --heading)           HEADING="$2"; shift 2 ;;
        --default-branch)    DEFAULT_BRANCH="$2"; shift 2 ;;
        --head-ref)          HEAD_REF="$2"; shift 2 ;;
        --base-ref)          BASE_REF="$2"; shift 2 ;;
        --pr-url)            PR_URL="$2"; shift 2 ;;
        --pr-number)         PR_NUMBER="$2"; shift 2 ;;
        --skip-review)       SKIP_REVIEW=1; shift ;;
        --companion)         COMPANION="$2"; shift 2 ;;
        -h|--help)           usage; exit 0 ;;
        *) echo "ERROR: unknown arg: $1" >&2; usage >&2; exit 30 ;;
    esac
done

require() {
    local name="$1" val="$2"
    if [[ -z "$val" ]]; then
        echo "ERROR: missing required arg: $name" >&2
        exit 30
    fi
}

require --mode "$MODE"
require --vault "$VAULT"
require --slug "$SLUG"
require --repo-url "$REPO_URL"
require --task-file "$TASK_FILE"
require --staging-heading "$STAGING_HEADING"
require --heading "$HEADING"

case "$MODE" in
    standard)
        require --default-branch "$DEFAULT_BRANCH"
        ;;
    adopt)
        require --head-ref "$HEAD_REF"
        require --base-ref "$BASE_REF"
        require --pr-url "$PR_URL"
        ;;
    *)
        echo "ERROR: --mode must be 'standard' or 'adopt' (got: $MODE)" >&2
        exit 30
        ;;
esac

# --- Step 1: derive paths --------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLOUDE_ROOT="${CLOUDE_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

# Parse --repo-url. Handles both:
#   git@github.com:OWNER/REPO[.git]
#   https://github.com/OWNER/REPO[.git]
parse_repo_url() {
    local url="$1"
    local owner_repo
    case "$url" in
        git@github.com:*)         owner_repo="${url#git@github.com:}" ;;
        https://github.com/*)     owner_repo="${url#https://github.com/}" ;;
        *) echo "ERROR: unsupported --repo-url shape: $url" >&2; exit 30 ;;
    esac
    owner_repo="${owner_repo%.git}"
    OWNER="${owner_repo%%/*}"
    REPO_NAME="${owner_repo#*/}"
    HTTPS_CLONE_URL="https://github.com/$OWNER/$REPO_NAME.git"
}
parse_repo_url "$REPO_URL"

SOURCE_CLONE="$CLOUDE_ROOT/vaults/$VAULT/repos/$REPO_NAME"
WORKTREE="$CLOUDE_ROOT/vaults/$VAULT/worktrees/$REPO_NAME/$SLUG"
TMUX_SESSION="cloude-$SLUG"

# Track what we managed to do so a mid-flow failure can describe state.
DONE_STEPS=()
record() { DONE_STEPS+=("$1"); }
bail() {
    local code="$1" msg="$2"
    {
        echo "ERROR: $msg"
        echo "Succeeded so far:"
        if ((${#DONE_STEPS[@]})); then
            printf '  - %s\n' "${DONE_STEPS[@]}"
        else
            echo "  (nothing)"
        fi
    } >&2
    exit "$code"
}

# --- Step 2: ensure source clone -------------------------------------------

if [[ ! -d "$SOURCE_CLONE" ]]; then
    mkdir -p "$CLOUDE_ROOT/vaults/$VAULT/repos"
    if ! gh repo clone "$OWNER/$REPO_NAME" "$SOURCE_CLONE" >/dev/null 2>&1; then
        bail 10 "gh repo clone $OWNER/$REPO_NAME failed"
    fi
    if ! git -C "$SOURCE_CLONE" remote set-url origin "$HTTPS_CLONE_URL"; then
        bail 10 "git remote set-url origin <https> failed"
    fi
    if ! git -C "$SOURCE_CLONE" config \
            credential."https://github.com".helper '!gh auth git-credential'; then
        bail 10 "git config credential helper failed"
    fi
    record "Cloned $OWNER/$REPO_NAME → $SOURCE_CLONE"
else
    record "Source clone present at $SOURCE_CLONE"
fi

# --- Step 3: create worktree + branch --------------------------------------

mkdir -p "$(dirname "$WORKTREE")"

if [[ "$MODE" == "standard" ]]; then
    BRANCH="cloude/$SLUG"
    if ! git -C "$SOURCE_CLONE" fetch origin "$DEFAULT_BRANCH" >/dev/null 2>&1; then
        bail 11 "git fetch origin $DEFAULT_BRANCH failed"
    fi
    if ! git -C "$SOURCE_CLONE" worktree add -b "$BRANCH" "$WORKTREE" \
            "origin/$DEFAULT_BRANCH" >/dev/null 2>&1; then
        bail 11 "git worktree add $BRANCH failed"
    fi
    record "Worktree + branch '$BRANCH' off origin/$DEFAULT_BRANCH"
    # Seed the branch with an empty commit. Without at least one commit
    # ahead of the base, `gh pr create` fails with "No commits between
    # <base> and <branch>".
    if ! git -C "$WORKTREE" commit --allow-empty \
            -m "Seed branch for task $(basename "$TASK_FILE" .org)" \
            >/dev/null 2>&1; then
        bail 11 "git commit --allow-empty failed"
    fi
    record "Seeded $BRANCH with an empty commit"
    if ! git -C "$WORKTREE" push -u origin "$BRANCH" >/dev/null 2>&1; then
        bail 11 "git push -u origin $BRANCH failed"
    fi
    record "Pushed $BRANCH to origin"
else
    BRANCH="$HEAD_REF"
    if ! git -C "$SOURCE_CLONE" fetch origin \
            "$HEAD_REF:refs/remotes/origin/$HEAD_REF" >/dev/null 2>&1; then
        bail 11 "git fetch origin $HEAD_REF failed"
    fi
    # Use -B if the local branch already exists; otherwise -b.
    local_branch_flag="-b"
    if git -C "$SOURCE_CLONE" show-ref --verify --quiet "refs/heads/$BRANCH"; then
        local_branch_flag="-B"
    fi
    if ! git -C "$SOURCE_CLONE" worktree add "$local_branch_flag" "$BRANCH" \
            "$WORKTREE" "origin/$HEAD_REF" >/dev/null 2>&1; then
        bail 11 "git worktree add $BRANCH failed"
    fi
    record "Worktree on $BRANCH tracking origin/$HEAD_REF"
fi

# --- Step 4: (standard) open draft PR --------------------------------------

if [[ "$MODE" == "standard" ]]; then
    task_id="$(basename "$TASK_FILE" .org)"
    pr_body="Draft PR for task $task_id. Plan to follow."
    if ! PR_URL="$(gh pr create --draft \
            --base "$DEFAULT_BRANCH" --head "$BRANCH" \
            --title "$HEADING" --body "$pr_body" \
            -R "$OWNER/$REPO_NAME" 2>&1)"; then
        bail 12 "gh pr create failed: $PR_URL"
    fi
    # gh pr create prints the URL on the last line. Keep only that.
    PR_URL="$(printf '%s\n' "$PR_URL" | tail -n1)"
    record "Opened draft PR $PR_URL"
fi

# --- Step 5: render the task file -----------------------------------------

TEMPLATE="$CLOUDE_ROOT/tasks/TEMPLATE.org"
if [[ ! -f "$TEMPLATE" ]]; then
    bail 13 "TEMPLATE not found: $TEMPLATE"
fi

mkdir -p "$(dirname "$TASK_FILE")"

# task_id = filename minus .org. ID property uses the YYYY-MM-DD-slug form.
TASK_ID="$(basename "$TASK_FILE" .org)"

# Per-mode setup: the starting stage (mode→stage mapping lives in
# cloude_stages so a future workflow change is one edit in one file)
# and the optional NOTES_PRELUDE pre-fill.
NEW_TODO="$("$SCRIPT_DIR/cloude-stages" starting-stage "$MODE")" \
    || bail 13 "cloude-stages starting-stage $MODE failed"
NEW_HEADING="$HEADING"
case "$MODE" in
    standard) NOTES_PRELUDE="" ;;
    adopt)    NOTES_PRELUDE="Adopted from PR $PR_URL" ;;
esac

# Render TEMPLATE.org → $TASK_FILE via the shared
# cloude_org.render_task_from_template helper. Booleans for adopted
# and skip_review are passed as "1" / "" so the bool() coercion on
# the Python side gives the right truthiness without arg munging.
ADOPTED_FLAG=""; [[ "$MODE" == "adopt" ]] && ADOPTED_FLAG=1
SKIP_REVIEW_FLAG=""; [[ -n "$SKIP_REVIEW" ]] && SKIP_REVIEW_FLAG=1
if ! CLOUDE_ROOT="$CLOUDE_ROOT" "$SCRIPT_DIR/cloude-python" -c '
import os, sys
from pathlib import Path
sys.path.insert(0, os.path.join(os.environ["CLOUDE_ROOT"], "bin"))
from cloude_org import render_task_from_template
(tmpl, dest, todo, heading, task_id, vault, repo_url, branch, worktree,
 pr_url, adopted_flag, skip_review_flag, companion, notes_prelude) = sys.argv[1:]
out = render_task_from_template(
    Path(tmpl).read_text(),
    todo=todo, heading=heading, task_id=task_id, vault=vault,
    repo_url=repo_url, branch=branch, worktree=worktree, pr_url=pr_url,
    adopted=bool(adopted_flag), skip_review=bool(skip_review_flag),
    companion=companion, notes_prelude=notes_prelude,
)
Path(dest).write_text(out)
' "$TEMPLATE" "$TASK_FILE" "$NEW_TODO" "$NEW_HEADING" "$TASK_ID" \
    "$VAULT" "$REPO_URL" "$BRANCH" "$WORKTREE" "$PR_URL" \
    "$ADOPTED_FLAG" "$SKIP_REVIEW_FLAG" "$COMPANION" "$NOTES_PRELUDE"; then
    bail 13 "task-file render failed"
fi
record "Rendered task file $TASK_FILE"

# --- Step 5b: seed the initial log entry ----------------------------------
# Appends a fresh `*** <STAGE> (via /promote)` entry under `** Log` with
# pre-seeded DoD checkboxes from `cloude_org.STAGE_DOD`. The stage
# matches NEW_TODO (PLANNING for standard mode, ITERATING for ADOPT).
# Best-effort: a seeding failure warns but does not undo the render.

if ! CLOUDE_ROOT="$CLOUDE_ROOT" "$SCRIPT_DIR/cloude-python" -c '
import os, sys
from pathlib import Path
sys.path.insert(0, os.path.join(os.environ["CLOUDE_ROOT"], "bin"))
from cloude_org import append_log_entry_skeleton, find_log_section, now_ts
task_file, new_todo = sys.argv[1], sys.argv[2]
path = Path(task_file)
content = path.read_text()
if find_log_section(content) is None:
    sys.stderr.write(
        "cloude-promote-setup: task file has no ** Log section; "
        "initial log entry not seeded. Add the section to "
        "tasks/TEMPLATE.org to enable this.\n"
    )
    sys.exit(0)
try:
    new_content = append_log_entry_skeleton(
        content, stage=new_todo, via="/promote", prev_stage="", when=now_ts(),
    )
except ValueError as exc:
    sys.stderr.write(
        f"cloude-promote-setup: could not seed initial log entry: {exc}\n"
    )
    sys.exit(0)
path.write_text(new_content)
' "$TASK_FILE" "$NEW_TODO"; then
    : # already warned via stderr; do not fail the promote
fi
record "Seeded initial $NEW_TODO log entry"

# --- Step 6: remove the chosen sub-heading from staging.org ----------------

STAGING="$CLOUDE_ROOT/tasks/staging.org"
if [[ ! -f "$STAGING" ]]; then
    bail 14 "staging file not found: $STAGING"
fi

# Both modes pre-fill the new container's Claude Code input box with
# the promoted staging entry. Capture that entry's body text into a
# temp file as it's removed below; step 6b assembles the prompt from
# it.
STAGING_BODY_FILE="$(mktemp "${TMPDIR:-/tmp}/cloude-staging-body.XXXXXX")"

if ! CLOUDE_ROOT="$CLOUDE_ROOT" "$SCRIPT_DIR/cloude-python" -c '
import os, sys
from pathlib import Path
sys.path.insert(0, os.path.join(os.environ["CLOUDE_ROOT"], "bin"))
from cloude_org import remove_staging_entry
staging, target, body_out = sys.argv[1], sys.argv[2].strip(), sys.argv[3]
path = Path(staging)
try:
    new_content, body = remove_staging_entry(path.read_text(), target)
except ValueError as exc:
    sys.exit(f"heading not found in {path}: {target!r}")
if body_out:
    Path(body_out).write_text(body)
path.write_text(new_content)
' "$STAGING" "$STAGING_HEADING" "$STAGING_BODY_FILE"; then
    bail 14 "removing staging entry failed"
fi
record "Removed staging entry"

# --- Step 6b: assemble the planning-prompt prefill (standard only) ---------
#
# The prompt is just the promoted staging entry — its heading, plus any
# body text. Simple by design: a simple prompt suffices for a simple
# task, and for anything bigger the user edits it before pressing
# Enter. bin/cloude-prefill-prompt (launched in step 7) pastes it into
# the new container's Claude Code input box, unsent.
PROMPT_FILE="$(mktemp "${TMPDIR:-/tmp}/cloude-prefill-prompt.XXXXXX")"
{
    printf '%s\n' "$HEADING"
    if [[ -n "$STAGING_BODY_FILE" && -s "$STAGING_BODY_FILE" ]]; then
        printf '\n'
        cat "$STAGING_BODY_FILE"
        printf '\n'
    fi
} >"$PROMPT_FILE"
rm -f "$STAGING_BODY_FILE"

# --- Step 7: create tmux session -------------------------------------------

if tmux has-session -t "=$TMUX_SESSION" 2>/dev/null; then
    bail 20 "tmux session '$TMUX_SESSION' already exists"
fi
# -e sets CLOUDE_TASK_FILE in the session environment, which the
# initial pane (and any later windows/panes) inherits - so the host
# shell left behind by `exec bash` knows which task this session is.
if ! tmux new-session -d -s "$TMUX_SESSION" -c "$WORKTREE" \
        -e "CLOUDE_TASK_FILE=$TASK_FILE" \
        "$CLOUDE_ROOT/bin/cloude-run $WORKTREE $TASK_FILE; exec bash"; then
    bail 20 "tmux new-session failed"
fi
record "Created tmux session $TMUX_SESSION"

# Second window: a live, read-only view of the task .org file. The
# helper picks emacs > vim/nvim/vi > generic $EDITOR; if none is
# available it prints an error and the `; exec bash` tail keeps the
# window at a shell so the user can fix their env.
tmux rename-window -t "$TMUX_SESSION:0" agent
tmux new-window -t "$TMUX_SESSION:" -c "$WORKTREE" -n task \
    "$CLOUDE_ROOT/bin/cloude-open-task-file $TASK_FILE; exec bash"
tmux select-window -t "$TMUX_SESSION:0"
record "Added task editor window to $TMUX_SESSION"

# Pre-fill the new container's Claude Code input box with the promoted
# staging entry. Applies to both modes — in standard mode this is the
# planning prompt; in ADOPT mode it's the user's direction about what
# to do with the adopted PR. Detached and best-effort:
# cloude-prefill-prompt polls the tmux pane in the background and
# removes $PROMPT_FILE itself when done, so /promote returns
# immediately; if the container never reaches the input box the box is
# simply left empty.
PREFILL_QUEUED=""
if [[ -n "$PROMPT_FILE" && -s "$PROMPT_FILE" ]]; then
    setsid "$CLOUDE_ROOT/bin/cloude-prefill-prompt" \
        "$TMUX_SESSION" "$PROMPT_FILE" </dev/null >/dev/null 2>&1 &
    PREFILL_QUEUED=1
    record "Queued prompt prefill for $TMUX_SESSION"
fi

# --- Step 8: summary -------------------------------------------------------

if [[ "$MODE" == "standard" ]]; then
    cat <<EOF
Mode: standard
Active task file: $TASK_FILE
Source clone: $SOURCE_CLONE
Branch: $BRANCH (based on $DEFAULT_BRANCH)
Worktree: $WORKTREE
Draft PR: $PR_URL
tmux session: $TMUX_SESSION (attach with: tmux attach -t $TMUX_SESSION)
Staging entry removed: yes
Starting state: PLANNING :user: — waiting for the user's planning prompt.
EOF
else
    cat <<EOF
Mode: ADOPT (PR #$PR_NUMBER)
Active task file: $TASK_FILE
Source clone: $SOURCE_CLONE
Branch: $BRANCH (tracking origin/$HEAD_REF)
Worktree: $WORKTREE
Existing PR: $PR_URL
tmux session: $TMUX_SESSION (attach with: tmux attach -t $TMUX_SESSION)
Staging entry removed: yes
Starting state: ITERATING :user: — waiting for the user's direction on the adopted PR.
EOF
fi

if [[ -n "$PREFILL_QUEUED" ]]; then
    echo "Prompt: queued to pre-fill the container's Claude Code input box — attach and press Enter to send (or edit the prompt first)."
fi

if [[ -n "$SKIP_REVIEW" ]]; then
    echo "Peer review: skipped — :SKIP_REVIEW: t set; /advance skips the REVIEW stage (ITERATING → MERGING)."
fi

if [[ -n "$COMPANION" ]]; then
    echo "Companion task: :COMPANION: $COMPANION rendered into the task file."
fi
