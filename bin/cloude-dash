#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["orgparse>=0.4", "inotify_simple>=1.3; sys_platform == 'linux'"]
# ///
# Curses dashboard for the state of all cloude tasks.
#
# Reads every org file under tasks/ (active, staging, completed, dropped)
# and renders a single ranked view: active first (sorted by stage
# priority), then staging ideas, then a tail of recently
# completed/dropped tasks. Enter on a row with a :PR: property opens
# the PR in the default browser.

from __future__ import annotations

import curses
import functools
import os
import shutil
import subprocess
import sys
import time
import webbrowser
from dataclasses import dataclass
from pathlib import Path
from urllib.parse import urlsplit

try:
    import orgparse
except ModuleNotFoundError:
    sys.stderr.write(
        "cloude-dash: orgparse is required.\n"
        "Launch via 'uv run bin/cloude-dash' (uv handles deps automatically),\n"
        "or 'pip install --user orgparse' and rerun.\n"
    )
    sys.exit(1)


CLOUDE_ROOT = Path(__file__).resolve().parent.parent
TASKS = CLOUDE_ROOT / "tasks"

ACTIVE = "ACTIVE"
STAGING = "STAGING"
TODO = "TODO"
RECENT = "RECENT"

STAGE_ORDER = {"MERGING": 0, "REVIEW": 1, "ITERATING": 2, "PLANNING": 3}
BALL_TAGS = ("agent", "user", "blocked")
# Terminal TODO keywords: a task in one of these is done, so its
# who-has-the-ball tag is stale noise and is not drawn.
TERMINAL_STATES = frozenset({"COMPLETE", "DROPPED"})
RECENT_LIMIT = 20


@dataclass
class Task:
    section: str
    state: str          # TODO keyword, or "" for staging ideas
    tag: str            # "agent" / "user" / "blocked" / ""
    title: str
    pr_url: str | None
    repo: str | None    # raw :REPO: URL at load; rewritten to the
                        # staging.org project header by load_tasks()
    path: Path
    ctime: float  # st_ctime, used to identify just-promoted ACTIVE
                  # rows and to sort the RECENT section by recency of
                  # the active/ -> completed/ / dropped/ rename.


def _ball_tag(tags) -> str:
    for t in BALL_TAGS:
        if t in tags:
            return t
    return ""


def _load_single_task_file(path: Path, section: str) -> Task | None:
    try:
        root = orgparse.load(str(path))
    except Exception:
        return None
    headings = [n for n in root.children]
    if not headings:
        return None
    h = headings[0]
    props = dict(h.properties) if h.properties else {}
    pr = props.get("PR") or None
    return Task(
        section=section,
        state=(h.todo or "").strip(),
        tag=_ball_tag(h.tags),
        title=str(h.heading).strip(),
        pr_url=pr if pr else None,
        repo=props.get("REPO") or None,
        path=path,
        ctime=path.stat().st_ctime,
    )


def _load_staging(
    path: Path,
) -> tuple[list[Task], dict[str, list[Task]], dict[str, str]]:
    """Split staging children into (staging, todo_sections, repo_names).

    Projects with a `:REPO:` property hold promotable ideas, which go
    into `staging`. Projects without `:REPO:` hold personal todos; we
    bucket their entries by org TODO keyword (`DONE`, `WAITING`, …)
    so the dashboard can render a section header per keyword. Entries
    that have no TODO keyword fall back to a default `TODO` bucket.

    `repo_names` maps each project's `:REPO:` URL (normalized via
    `_repo_key`) to that project's heading text, so any task carrying
    the same `:REPO:` URL can be labelled with the human-named project
    header on the dashboard.
    """
    if not path.exists():
        return [], {}, {}
    try:
        root = orgparse.load(str(path))
    except Exception:
        return [], {}, {}
    staging: list[Task] = []
    todo_sections: dict[str, list[Task]] = {}
    repo_names: dict[str, str] = {}
    ctime = path.stat().st_ctime
    for project in root.children:
        props = dict(project.properties) if project.properties else {}
        repo_url = props.get("REPO") or None
        is_promotable = bool(repo_url)
        project_name = str(project.heading).strip()
        if repo_url:
            repo_names.setdefault(_repo_key(repo_url), project_name)
        for idea in project.children:
            idea_title = str(idea.heading).strip()
            tag = _ball_tag(idea.tags)
            if is_promotable:
                staging.append(
                    Task(
                        section=STAGING,
                        state="",
                        tag=tag,
                        title=idea_title,
                        pr_url=None,
                        repo=repo_url,
                        path=path,
                        ctime=ctime,
                    )
                )
            else:
                keyword = (idea.todo or "").strip() or TODO
                # Non-repo rows carry the parent project name as a
                # prefix so the dashboard shows project grouping
                # alongside the TODO-keyword grouping.
                title = f"[{project_name}] {idea_title}"
                todo_sections.setdefault(keyword, []).append(
                    Task(
                        section=keyword,
                        state="",
                        tag=tag,
                        title=title,
                        pr_url=None,
                        repo=None,
                        path=path,
                        ctime=ctime,
                    )
                )
    return staging, todo_sections, repo_names


def _repo_path(url: str) -> str:
    """Reduce a repo URL/identifier to its 'owner/repo' path.

    The `https://github.com/owner/repo` form (and any other scheme) is
    parsed with `urllib.parse.urlsplit`, which yields the host-less
    path directly. The scp-like SSH form `git@github.com:owner/repo`
    is not a real URL, so it is first promoted to an `ssh://` URL so
    the same parser handles it. A trailing slash and a `.git` suffix
    are trimmed; a bare `owner/repo` passes through. Case is preserved
    — this feeds the human-facing fallback label.
    """
    s = url.strip()
    if "://" not in s and "@" in s:
        # scp-like SSH (git@host:owner/repo): promote to a proper
        # ssh:// URL by turning the host/path ':' into a '/'.
        s = "ssh://" + s.replace(":", "/", 1)
    path = urlsplit(s).path.strip("/")
    return path.removesuffix(".git")


def _repo_key(url: str) -> str:
    """Canonical, case-folded lookup key for matching a repo URL across
    its https / SSH / .git-suffixed forms."""
    return _repo_path(url).lower()


def _repo_label(url: str | None, repo_names: dict[str, str]) -> str:
    """Display label for a task's repo: the staging.org project header
    when the URL matches a known project, else an `owner/repo` fallback
    so the row still shows something useful."""
    if not url:
        return ""
    return repo_names.get(_repo_key(url)) or _repo_path(url)


def load_tasks() -> dict[str, list[Task] | dict[str, list[Task]]]:
    # Load staging first: it yields the repo-URL -> project-header map
    # used to label every other task's :REPO: URL below.
    staging, todo_sections, repo_names = _load_staging(TASKS / "staging.org")

    active: list[Task] = []
    for p in sorted((TASKS / "active").glob("*.org")):
        t = _load_single_task_file(p, ACTIVE)
        if t:
            active.append(t)
    active.sort(key=lambda t: (STAGE_ORDER.get(t.state, 99), t.path.name))

    recent: list[Task] = []
    for sub, label in (("completed", "COMPLETE"), ("dropped", "DROPPED")):
        d = TASKS / sub
        if not d.exists():
            continue
        for p in d.glob("*.org"):
            t = _load_single_task_file(p, RECENT)
            if t:
                if not t.state:
                    t.state = label
                recent.append(t)
    recent.sort(key=lambda t: t.ctime, reverse=True)
    recent = recent[:RECENT_LIMIT]

    # Rewrite each task's raw :REPO: URL to its staging.org project
    # header (todo_sections rows carry no repo and are left alone).
    for t in (*active, *staging, *recent):
        t.repo = _repo_label(t.repo, repo_names)

    return {
        ACTIVE: active,
        STAGING: staging,
        TODO: todo_sections,
        RECENT: recent,
    }


# --- rendering -------------------------------------------------------------

# Row kinds for the flattened display list.
ROW_HEADER = "header"
ROW_TASK = "task"
ROW_EMPTY = "empty"


def _flatten(
    groups: dict[str, list[Task] | dict[str, list[Task]]],
    query: str = "",
) -> list[tuple[str, object]]:
    """Flatten the loaded task groups into a list of (kind, payload) rows.

    When `query` is non-empty, ROW_TASK rows whose title does not contain
    the query (case-insensitive) are dropped, sections with zero
    surviving rows are hidden entirely, and surviving section headers
    show `LABEL (matched/total)` so the user sees the breakdown."""
    rows: list[tuple[str, object]] = []
    needle = query.lower()
    filtering = bool(needle)

    def matches(t: Task) -> bool:
        return needle in t.title.lower()

    def emit(label: str, items: list[Task], *, show_empty: bool) -> None:
        kept = [t for t in items if matches(t)] if filtering else items
        # With a filter active, collapse sections that have no matches —
        # the user only wants to see what survived.
        if filtering and not kept:
            return
        if not kept and not show_empty:
            return
        if filtering:
            header = f"{label} ({len(kept)}/{len(items)})"
        else:
            header = f"{label} ({len(items)})"
        rows.append((ROW_HEADER, header))
        if not kept:
            rows.append((ROW_EMPTY, None))
            return
        for t in kept:
            rows.append((ROW_TASK, t))

    emit(ACTIVE, groups[ACTIVE], show_empty=True)  # type: ignore[arg-type]
    emit(STAGING, groups[STAGING], show_empty=True)  # type: ignore[arg-type]
    # One header per non-repo TODO keyword, sorted alphabetically.
    # Empty buckets are not emitted — a bucket only exists if it has
    # entries, so this just walks the discovered keywords in order.
    todo_sections: dict[str, list[Task]] = groups[TODO]  # type: ignore[assignment]
    for label in sorted(todo_sections):
        emit(label, todo_sections[label], show_empty=False)
    emit(RECENT, groups[RECENT], show_empty=True)  # type: ignore[arg-type]
    return rows


def _selectable_indices(rows) -> list[int]:
    return [i for i, (kind, _) in enumerate(rows) if kind == ROW_TASK]


def _newest_active_row_index(rows) -> int | None:
    """Index of the ACTIVE ROW_TASK with the freshest `Task.ctime`, or
    None when there are no ACTIVE rows.

    Used to land the highlight on the just-promoted task after a
    successful `P` keypress: the promote chain's final step writes a
    new `tasks/active/<date>-<slug>.org`, so its ctime is
    overwhelmingly the freshest among ACTIVE rows. RECENT rows are
    intentionally ignored — a just-finalized task lives in
    `completed/` with a very fresh ctime from the active/->completed/
    rename, and we never want the cursor to jump there.
    """
    best_idx: int | None = None
    best_ctime = float("-inf")
    for i, (kind, payload) in enumerate(rows):
        if kind != ROW_TASK:
            continue
        t: Task = payload  # type: ignore[assignment]
        if t.section != ACTIVE:
            continue
        if t.ctime > best_ctime:
            best_ctime = t.ctime
            best_idx = i
    return best_idx


def _task_key(t: Task) -> tuple[str, str]:
    """Stable identity for a task, used to keep the highlight on the
    same task across a reload that reorders rows.

    The filename is preserved when a task file moves active/ ->
    completed/ / dropped/ (only the directory changes), so it pins a
    logical task even as its section changes. STAGING and TODO-keyword
    rows all share the single staging.org path, so the title
    disambiguates them."""
    return (t.path.name, t.title)


def _pr_number(url: str | None) -> str:
    if not url:
        return ""
    tail = url.rstrip("/").split("/")[-1]
    return f"PR #{tail}" if tail.isdigit() else url


def _date_from_filename(path: Path) -> str:
    name = path.stem
    return name[:10] if len(name) >= 10 and name[4] == "-" else ""


def _slug_from_filename(path: Path) -> str:
    name = path.stem
    return name[11:] if len(name) > 11 and name[4] == "-" else name


# Clipboard utilities tried in order; the first whose binary is on
# PATH wins. wl-copy = Wayland, xclip / xsel = X11, pbcopy = macOS.
_CLIPBOARD_TOOLS = (
    ["wl-copy"],
    ["xclip", "-selection", "clipboard"],
    ["xsel", "--clipboard", "--input"],
    ["pbcopy"],
)


@functools.lru_cache(maxsize=1)
def _detect_clipboard_tool() -> list[str] | None:
    """Pick the clipboard command to use: the first entry of
    `_CLIPBOARD_TOOLS` whose binary is found on PATH. Returns the full
    argv (or None when no clipboard utility is installed).

    `lru_cache` makes the PATH probe run exactly once — on the first
    copy — so every later `_copy_to_clipboard` call reuses the result
    instead of re-scanning PATH."""
    for cmd in _CLIPBOARD_TOOLS:
        if shutil.which(cmd[0]):
            return cmd
    return None


def _copy_to_clipboard(text: str) -> str | None:
    """Copy `text` to the system clipboard using the tool chosen by
    `_detect_clipboard_tool`. Returns that tool's name on success, or
    None when no clipboard utility is available or the copy failed."""
    cmd = _detect_clipboard_tool()
    if cmd is None:
        return None
    try:
        # stdout/stderr go to DEVNULL (not PIPE) so the clipboard
        # daemon that xclip/xsel fork to keep the X selection alive
        # cannot inherit pipe fds we'd then block reading until EOF.
        r = subprocess.run(
            cmd,
            input=text,
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except OSError:
        return None
    return cmd[0] if r.returncode == 0 else None


def _tmux_session_for(t: Task) -> str | None:
    if t.section != ACTIVE:
        return None
    slug = _slug_from_filename(t.path)
    return f"cloude-{slug}" if slug else None


def _switch_tmux(stdscr, t: Task) -> str:
    session = _tmux_session_for(t)
    if not session:
        return "(no tmux session: not an active task)"
    has = subprocess.run(
        ["tmux", "has-session", "-t", f"={session}"],
        capture_output=True,
    )
    if has.returncode != 0:
        return f"(no tmux session: {session})"
    if os.environ.get("TMUX"):
        r = subprocess.run(
            ["tmux", "switch-client", "-t", session],
            capture_output=True,
            text=True,
        )
        if r.returncode != 0:
            return f"(tmux switch-client failed: {r.stderr.strip()})"
        return f"switched to {session}"
    # Outside tmux: suspend curses, attach inline; resume on detach.
    curses.endwin()
    try:
        subprocess.run(["tmux", "attach", "-t", session])
    finally:
        stdscr.clear()
        stdscr.refresh()
        curses.doupdate()
    return f"detached from {session}"


_PROMOTE_EXIT_MESSAGES = {
    30: "argument error",
    40: "staging lookup failed",
    41: "slug is empty",
    42: "gh call failed",
    43: "ADOPT PR is not OPEN / cross-repo / repo mismatch",
}

# Idle-tick timeout (ms) for the main getch() loop in _run(). The
# promote modal's run loop drops it to a faster tick while the
# subprocess streams output, then restores this value on the way out.
_MAIN_LOOP_TIMEOUT_MS = 500
_MODAL_RUN_TICK_MS = 50


def _wrap_lines(text: str, width: int) -> list[str]:
    """Split `text` on newlines, then hard-wrap each line to fit `width`.

    Each input line is broken into one or more output lines, each at
    most `width` characters. Empty lines are preserved. `width` must
    be >= 1; the modal's inner-width calc guarantees that.
    """
    if width < 1:
        return []
    out: list[str] = []
    for line in text.split("\n"):
        if not line:
            out.append("")
            continue
        while len(line) > width:
            out.append(line[:width])
            line = line[width:]
        out.append(line)
    return out


def _draw_modal(
    stdscr,
    *,
    title_prefix: str,
    title: str,
    body: str,
    footer: str,
    body_placeholder: str = "",
) -> None:
    """Draw a centered modal box over the dashboard.

    Centered, bordered window sized to the terminal with a small
    margin. Body tail-renders so the newest output is always visible.
    The dashboard underneath is not erased — only the modal's mh*mw
    cells are written, so the rows at the margins stay readable.

    A fresh curses.newwin is built each call: cheap, and a clean way
    to absorb terminal resizes that happen between ticks.

    `body_placeholder` is shown only when `body` would otherwise
    render zero non-empty lines — used while a subprocess hasn't
    emitted output yet so the modal isn't visually empty.
    """
    h, w = stdscr.getmaxyx()
    mh = min(h, max(10, h - 4))
    mw = min(w, max(40, w - 6))
    y0 = max(0, (h - mh) // 2)
    x0 = max(0, (w - mw) // 2)

    win = curses.newwin(mh, mw, y0, x0)
    win.erase()
    win.border()

    header = f" {title_prefix}: {title} "
    win.addnstr(0, 2, header, mw - 4, curses.A_BOLD)
    win.addnstr(mh - 1, 2, footer, mw - 4, curses.A_DIM)

    inner_h = max(0, mh - 2)
    inner_w = max(1, mw - 4)
    wrapped = _wrap_lines(body, inner_w)
    if body_placeholder and not any(line for line in wrapped):
        wrapped = [body_placeholder]
    visible = wrapped[-inner_h:] if inner_h else []
    for i, line in enumerate(visible):
        win.addnstr(1 + i, 2, line, inner_w)

    win.refresh()


def _format_exit_footer(
    exit_code: int | None, exit_messages: dict[int, str]
) -> str:
    """Footer text for a finished subprocess: `exit N (reason) — Enter/q
    to close`, dropping the parenthetical when the code isn't mapped.
    Returns the success footer when `exit_code` is 0."""
    if exit_code == 0:
        return " exit 0 — Enter/q to close "
    reason = (
        exit_messages.get(exit_code) if exit_code is not None else None
    )
    if reason:
        return f" exit {exit_code} ({reason}) — Enter/q to close "
    return f" exit {exit_code} — Enter/q to close "


def _draw_promote_modal(
    stdscr,
    *,
    title: str,
    body: str,
    elapsed: float,
    running: bool,
    exit_code: int | None,
) -> None:
    """Draw the promote modal over the dashboard.

    Thin footer-and-placeholder wrapper over the generic `_draw_modal`.
    """
    if running:
        footer = f" running… ({elapsed:.1f}s) "
    else:
        footer = _format_exit_footer(exit_code, _PROMOTE_EXIT_MESSAGES)
    _draw_modal(
        stdscr,
        title_prefix="promote",
        title=title,
        body=body,
        footer=footer,
        body_placeholder=(
            "(running cloude-promote — no output yet)" if running else ""
        ),
    )


def _run_promote_modal(stdscr, idx: int, title: str, dashboard_redraw) -> int:
    """Run `bin/cloude-promote --select idx` and drive the modal loop.

    Spawns the orchestrator with stderr merged into stdout (the chain
    writes the summary block to stdout on success and the failure
    block to stderr only on failure, never both in the same run, so
    merging keeps ordering safe). The pipe fd is set non-blocking;
    each ~50ms tick reads any available bytes, polls for exit, and
    redraws. After exit + EOF the modal stays up until the user
    presses Enter, q, or Esc. Keys during the run are dropped — the
    chain mutates filesystem state mid-stride (clone, branch push,
    draft PR, task-file render, staging.org edit, tmux session) and
    there's no safe cancel point.

    `dashboard_redraw` is called before each modal paint so the
    dashboard underneath the overlay stays at the current terminal
    dimensions — that's what makes the modal margins repaint on
    resize too.
    """
    script = Path(__file__).resolve().parent / "cloude-promote"
    proc = subprocess.Popen(
        [str(script), "--select", str(idx)],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    fd = proc.stdout.fileno()
    os.set_blocking(fd, False)

    buf = bytearray()
    start = time.monotonic()
    stdscr.timeout(_MODAL_RUN_TICK_MS)

    return_code: int | None = None
    eof = False

    def render() -> None:
        dashboard_redraw()
        _draw_promote_modal(
            stdscr,
            title=title,
            body=buf.decode("utf-8", "replace"),
            elapsed=time.monotonic() - start,
            running=return_code is None,
            exit_code=return_code,
        )

    try:
        while return_code is None or not eof:
            try:
                chunk = os.read(fd, 4096)
            except BlockingIOError:
                chunk = None
            if chunk:
                buf.extend(chunk)
            elif chunk == b"":
                eof = True

            if return_code is None:
                return_code = proc.poll()

            render()

            try:
                # Ignored while running; just paces the tick. KEY_RESIZE
                # gets acknowledged so curses' cached dimensions refresh
                # promptly — the next tick repaints at the new size.
                ch = stdscr.getch()
            except KeyboardInterrupt:
                ch = -1
            if ch == curses.KEY_RESIZE:
                _handle_resize(stdscr)

        render()
        # Block on key input now — no more polling needed. Use the
        # main loop's idle timeout so an inotify-triggered redraw of
        # the dashboard underneath still ticks at the normal cadence
        # while we wait for dismissal.
        stdscr.timeout(_MAIN_LOOP_TIMEOUT_MS)
        while True:
            try:
                ch = stdscr.getch()
            except KeyboardInterrupt:
                break
            if ch == curses.KEY_RESIZE:
                _handle_resize(stdscr)
                render()
                continue
            if ch in (ord("q"), 27, curses.KEY_ENTER, 10, 13):
                break
    finally:
        stdscr.timeout(_MAIN_LOOP_TIMEOUT_MS)
        if proc.poll() is None:
            proc.wait()

    return return_code if return_code is not None else 1


# Human-readable label per exit code documented in
# bin/cloude-finalize-cleanup's usage block. Used by the finalize modal
# to render `exit N (reason) — Enter/q to close` footers and to format
# the status-line message after the modal is dismissed.
_FINALIZE_EXIT_MESSAGES: dict[int, str] = {
    10: "PR not MERGED",
    11: "task not in terminal state",
    12: "worktree dirty / locked",
    13: "DinD volume in use",
    14: "worktree has foreign-owned files",
    15: "PR not accessible",
    20: "gh pr close failed",
    21: "task-file move failed",
    22: "cloude-task-info failed",
    23: "heading rewrite failed",
    25: "worktree removal failed even with --force",
    26: "root cleanup ran but worktree still present",
    30: "argument validation",
}


# Exit codes from bin/cloude-finalize-cleanup that signal a judgment
# call: the script bailed before the side effect, and rerunning with
# the matching override flag retries it. Maps {exit_code: (prompt,
# override_flag)}; the prompts mirror what /finalize's skill asks.
_FINALIZE_OVERRIDES: dict[int, tuple[str, str]] = {
    12: (
        "Worktree is dirty / locked. Force-remove (discards changes)? [y/N] ",
        "--force-worktree",
    ),
    13: (
        "DinD volume is still in use. Skip volume cleanup? [y/N] ",
        "--skip-volume",
    ),
    14: (
        "Worktree has foreign-owned files. Nuke via 'docker run --user root'? [y/N] ",
        "--force-root",
    ),
    15: (
        "PR not accessible (gh pr view failed). Proceed with cleanup anyway? [y/N] ",
        "--force-pr-absent",
    ),
}


def _modal_read_yn(stdscr, redraw) -> bool:
    """Block on stdscr until the user picks yes or no.

    `redraw` is called once up-front so the prompt is visible before
    the first getch, and again on every KEY_RESIZE so the modal
    re-flows at the new terminal dimensions. y/Y → True;
    n/N/Esc/q/Enter → False. Idle ticks (the curses timeout firing
    without input) just cycle — the modal contents aren't changing
    while we wait, matching the dismissal loop in
    `_run_promote_modal`.
    """
    stdscr.timeout(_MAIN_LOOP_TIMEOUT_MS)
    redraw()
    while True:
        try:
            ch = stdscr.getch()
        except KeyboardInterrupt:
            return False
        if ch == -1:
            continue
        if ch == curses.KEY_RESIZE:
            _handle_resize(stdscr)
            redraw()
            continue
        if ch in (ord("y"), ord("Y")):
            return True
        if ch in (
            ord("n"), ord("N"), ord("q"), 27,
            curses.KEY_ENTER, 10, 13,
        ):
            return False


def _modal_wait_dismiss(stdscr, redraw) -> None:
    """Block on stdscr until the user dismisses the modal with q / Esc /
    Enter. `redraw` is called once before blocking, and again on every
    KEY_RESIZE so the modal re-flows at the new terminal dimensions.
    Idle ticks cycle."""
    stdscr.timeout(_MAIN_LOOP_TIMEOUT_MS)
    redraw()
    while True:
        try:
            ch = stdscr.getch()
        except KeyboardInterrupt:
            return
        if ch == -1:
            continue
        if ch == curses.KEY_RESIZE:
            _handle_resize(stdscr)
            redraw()
            continue
        if ch in (ord("q"), 27, curses.KEY_ENTER, 10, 13):
            return


def _run_finalize_modal(stdscr, t: "Task", dashboard_redraw) -> tuple[int, bool]:
    """Drive `bin/cloude-finalize-cleanup` inside the dashboard's modal.

    Returns (exit_code, aborted). `aborted` is True iff the user
    answered N to a y/N prompt (initial force-drop or any override);
    on the initial-force-drop-N path no subprocess runs and exit_code
    is 0.

    Phases:
      1. If `t.state` is non-terminal, show a brief explanation in the
         body and `Force-drop and finalize? [y/N]` in the footer. On
         N return (0, True). On y, queue `--force-drop` and proceed.
      2. Spawn cloude-finalize-cleanup with the accumulated flag list;
         stream stdout (stderr merged) into the shared buffer at the
         _MODAL_RUN_TICK_MS cadence, redrawing each tick with a
         `running… (Ns)` footer.
      3. On exit 0 → success footer, wait for dismissal, return
         (0, False).
      4. On override-able exit (12/13/14) → prompt y/N; y appends the
         flag and loops back to step 2 (with a separator written into
         the buffer so the rerun boundary is visible); N → "aborted"
         footer, dismiss, return (exit, True).
      5. On any other non-zero exit → mapped reason in the footer,
         dismiss, return (exit, False).

    `dashboard_redraw` is called from `render` before the modal paint
    so the dashboard underneath stays at current dimensions across
    terminal resizes.
    """
    script = Path(__file__).resolve().parent / "cloude-finalize-cleanup"
    buf = bytearray()
    flags: list[str] = []

    def render(footer: str, *, body_placeholder: str = "") -> None:
        dashboard_redraw()
        _draw_modal(
            stdscr,
            title_prefix="finalize",
            title=t.title,
            body=buf.decode("utf-8", "replace"),
            footer=footer,
            body_placeholder=body_placeholder,
        )

    # Phase 1: initial force-drop confirmation for non-terminal tasks.
    if t.state not in TERMINAL_STATES:
        explainer = (
            f"Task is in {t.state or 'no'} state — not COMPLETE / DROPPED.\n"
            "Finalizing will flip the heading TODO to DROPPED, close the "
            "PR, and tear down the worktree / tmux session / DinD volume.\n"
        )
        buf.extend(explainer.encode())
        if not _modal_read_yn(
            stdscr, lambda: render(" Force-drop and finalize? [y/N] ")
        ):
            return 0, True
        flags.append("--force-drop")
        buf.extend(b"\n")

    # Phases 2-5: subprocess + override loop.
    last_code = 0
    while True:
        if last_code != 0:
            # Re-running with the override appended just now. The
            # separator marks the boundary in the accumulated buffer.
            buf.extend(
                f"--- rerunning with {flags[-1]} ---\n".encode()
            )

        proc = subprocess.Popen(
            [str(script), str(t.path), *flags],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
        fd = proc.stdout.fileno()
        os.set_blocking(fd, False)

        start = time.monotonic()
        stdscr.timeout(_MODAL_RUN_TICK_MS)

        return_code: int | None = None
        eof = False
        try:
            while return_code is None or not eof:
                try:
                    chunk = os.read(fd, 4096)
                except BlockingIOError:
                    chunk = None
                if chunk:
                    buf.extend(chunk)
                elif chunk == b"":
                    eof = True

                if return_code is None:
                    return_code = proc.poll()

                render(
                    f" running… ({time.monotonic() - start:.1f}s) ",
                    body_placeholder=(
                        "(running cloude-finalize-cleanup — no output yet)"
                    ),
                )

                try:
                    # Keys are ignored during the run; KEY_RESIZE is
                    # acknowledged so curses' cached dimensions refresh
                    # and the next tick paints at the new size.
                    ch = stdscr.getch()
                except KeyboardInterrupt:
                    ch = -1
                if ch == curses.KEY_RESIZE:
                    _handle_resize(stdscr)
        finally:
            if proc.poll() is None:
                proc.wait()

        last_code = return_code if return_code is not None else 1

        if last_code == 0:
            _modal_wait_dismiss(
                stdscr,
                lambda: render(
                    " finalize succeeded — Enter/q to close "
                ),
            )
            return 0, False

        if last_code in _FINALIZE_OVERRIDES:
            prompt, flag = _FINALIZE_OVERRIDES[last_code]
            footer = f" {prompt}"
            if _modal_read_yn(stdscr, lambda f=footer: render(f)):
                if flag not in flags:
                    flags.append(flag)
                continue
            _modal_wait_dismiss(
                stdscr,
                lambda: render(
                    " finalize aborted — Enter/q to close "
                ),
            )
            return last_code, True

        footer = _format_exit_footer(last_code, _FINALIZE_EXIT_MESSAGES)
        _modal_wait_dismiss(stdscr, lambda f=footer: render(f))
        return last_code, False


def _finalize_status_message(
    *, exit_code: int, aborted: bool, title: str
) -> str:
    """Status-line copy for the dashboard's footer after the finalize
    modal dismisses. Pure (no curses), so the table can be unit-tested
    without driving the modal itself."""
    if aborted:
        return "finalize aborted"
    if exit_code == 0:
        return f"finalized: {title}"
    reason = _FINALIZE_EXIT_MESSAGES.get(exit_code, f"exit {exit_code}")
    return f"finalize failed: {reason}"


def _promote_staging(stdscr, t: Task, staging: list[Task], dashboard_redraw) -> str:
    """Promote the highlighted STAGING row via `bin/cloude-promote`.

    The staging-order in `staging` matches `cloude-list-staging`'s
    numbering (both walk `tasks/staging.org`'s `root.children` and
    skip projects without `:REPO:` in the same order), so the
    1-based position is the `--select` index.

    The orchestrator's stdout/stderr stream into a curses modal
    overlay that stays inside the dashboard — no endwin() flash. The
    modal stays up after exit until Enter/q/Esc is pressed. Returns a
    status-line message describing the outcome (success or the
    mapped exit-code blurb).

    `dashboard_redraw` is a no-arg closure (captured from `_run`) that
    repaints the dashboard underneath the modal; the modal calls it
    each tick so a SIGWINCH-driven resize re-flows both layers at
    the new dimensions.
    """
    if t.section != STAGING:
        return "(P: only works on STAGING rows)"
    try:
        idx = staging.index(t) + 1
    except ValueError:
        return "(P: could not locate staging row)"

    script = Path(__file__).resolve().parent / "cloude-promote"
    if not script.exists():
        return f"(P: {script} not found)"

    return_code = _run_promote_modal(stdscr, idx, t.title, dashboard_redraw)

    if return_code == 0:
        return f"promoted: {t.title}"
    msg = _PROMOTE_EXIT_MESSAGES.get(return_code, f"exit {return_code}")
    return f"promote failed: {msg}"


def _finalize_task(stdscr, t: Task, dashboard_redraw) -> str:
    """Finalize the highlighted ACTIVE task via the modal-driven
    `bin/cloude-finalize-cleanup` wrapper.

    Pre-flight bails (wrong row kind, script missing) stay as
    status-line returns — no point opening a modal just to close it.
    Anything past that runs through `_run_finalize_modal`, which
    handles the initial force-drop prompt, the subprocess streaming,
    and the override y/N prompts. The status-line copy on dismissal
    is computed by `_finalize_status_message`.

    `dashboard_redraw` is forwarded into the modal so it can repaint
    the dashboard underneath on every tick — keeps the margins fresh
    across terminal resizes.
    """
    if t.section != ACTIVE:
        return "(f: only works on ACTIVE rows)"

    script = Path(__file__).resolve().parent / "cloude-finalize-cleanup"
    if not script.exists():
        return f"(f: {script} not found)"

    try:
        exit_code, aborted = _run_finalize_modal(stdscr, t, dashboard_redraw)
    finally:
        stdscr.timeout(_MAIN_LOOP_TIMEOUT_MS)
    return _finalize_status_message(
        exit_code=exit_code, aborted=aborted, title=t.title
    )


def _color(stdscr, tag: str) -> int:
    if not curses.has_colors():
        return 0
    return {
        "agent": curses.color_pair(1),
        "user": curses.color_pair(2),
        "blocked": curses.color_pair(3),
    }.get(tag, 0)


def _handle_resize(stdscr) -> None:
    """Acknowledge a SIGWINCH / curses.KEY_RESIZE.

    Refresh curses' cached LINES/COLS (so subsequent ``getmaxyx`` calls
    return the new dimensions) and clear stdscr so the next draw paints
    a clean canvas at the new size. The ``hasattr`` guard is defensive —
    ``update_lines_cols`` has been in CPython since 3.5 and this script
    requires 3.11.
    """
    if hasattr(curses, "update_lines_cols"):
        curses.update_lines_cols()
    stdscr.erase()
    stdscr.refresh()


def _draw(stdscr, rows, selected: int, status: str) -> None:
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    title = "cloude tasks"
    hint = "↑/↓ move  / search  p PR  t tmux  c copy slug  P promote  f finalize  r reload  q quit"
    stdscr.addnstr(0, 0, title, w - 1, curses.A_BOLD)
    if len(title) + len(hint) + 2 < w:
        stdscr.addnstr(0, w - len(hint) - 1, hint, len(hint), curses.A_DIM)

    y = 2
    for i, (kind, payload) in enumerate(rows):
        if y >= h - 1:
            break
        if kind == ROW_HEADER:
            stdscr.addnstr(y, 0, str(payload), w - 1, curses.A_BOLD | curses.A_UNDERLINE)
        elif kind == ROW_EMPTY:
            stdscr.addnstr(y, 2, "(none)", w - 3, curses.A_DIM)
        elif kind == ROW_TASK:
            t: Task = payload  # type: ignore[assignment]
            marker = ">" if i == selected else " "
            attr = curses.A_REVERSE if i == selected else 0
            state = (t.state or "—").ljust(9)
            # Terminal-state tasks (COMPLETE/DROPPED) still sitting in
            # tasks/active/ carry a stale tag — suppress it.
            show_tag = bool(t.tag) and t.state not in TERMINAL_STATES
            tag = f":{t.tag}:".ljust(10) if show_tag else "".ljust(10)
            repo = t.repo or ""
            if t.section == RECENT:
                date = _date_from_filename(t.path)
                slug = _slug_from_filename(t.path)
                line = f"{marker} {state} {date}  {slug}"
                right = repo
            else:
                line = f"{marker} {state} {tag} {t.title}"
                # Right margin: PR number then project header, two
                # spaces apart; either part may be absent.
                right = "  ".join(x for x in (_pr_number(t.pr_url), repo) if x)
            if right:
                pad = max(1, w - 1 - len(line) - len(right))
                line = line + (" " * pad) + right
            stdscr.addnstr(y, 0, line, w - 1, attr)
            if show_tag and t.section != RECENT and not attr:
                tag_str = f":{t.tag}:"
                tag_col = 2 + len(state) + 1
                if tag_col + len(tag_str) < w:
                    stdscr.addnstr(y, tag_col, tag_str, len(tag_str), _color(stdscr, t.tag))
        y += 1

    if status:
        stdscr.addnstr(h - 1, 0, status, w - 1, curses.A_DIM)
    stdscr.refresh()


def _follow_selection(rows, prev_key: tuple[str, str] | None, fallback: int) -> int:
    """Pick the selection index for freshly-reloaded `rows`.

    `prev_key` is the `_task_key` of the task highlighted before the
    reload, or None if no task was highlighted. If a row in the new
    `rows` carries that key, return its index so the highlight follows
    the task through any reordering. Otherwise (task gone, or nothing
    was selected) return `fallback`, clamped to a selectable row."""
    sels = _selectable_indices(rows)
    if prev_key is not None:
        for i in sels:
            if _task_key(rows[i][1]) == prev_key:
                return i
    if sels and fallback not in sels:
        return sels[0]
    return fallback


def _move_selection(rows, sel: int, delta: int) -> int:
    selectables = _selectable_indices(rows)
    if not selectables:
        return sel
    if sel not in selectables:
        return selectables[0]
    idx = selectables.index(sel)
    idx = max(0, min(len(selectables) - 1, idx + delta))
    return selectables[idx]


_WATCH_DIRS = (TASKS, TASKS / "active", TASKS / "completed", TASKS / "dropped")


class _Watcher:
    """Abstract base for file-change watchers."""

    def changed(self) -> bool:
        raise NotImplementedError

    @staticmethod
    def create() -> "_Watcher":
        """Return the best available watcher for this platform."""
        try:
            return _InotifyWatcher()
        except (ImportError, AttributeError, OSError):
            return _MtimeWatcher()


class _InotifyWatcher(_Watcher):
    """Event-driven watcher using inotify (Linux only)."""

    def __init__(self) -> None:
        from inotify_simple import INotify, flags as inotify_flags
        watch_flags = (
            inotify_flags.CREATE
            | inotify_flags.DELETE
            | inotify_flags.MODIFY
            | inotify_flags.MOVED_TO
            | inotify_flags.MOVED_FROM
            | inotify_flags.CLOSE_WRITE
        )
        self._inot = INotify()
        for d in _WATCH_DIRS:
            if d.is_dir():
                self._inot.add_watch(str(d), watch_flags)

    def changed(self) -> bool:
        events = self._inot.read(timeout=0)
        if events:
            time.sleep(0.05)  # debounce coalesces burst writes
            self._inot.read(timeout=0)
            return True
        return False


class _MtimeWatcher(_Watcher):
    """Polling watcher that compares mtimes (cross-platform fallback)."""

    def __init__(self) -> None:
        self._last_mtime = self._scan()

    def _scan(self) -> float:
        best = 0.0
        for d in _WATCH_DIRS:
            if not d.is_dir():
                continue
            try:
                best = max(best, d.stat().st_mtime)
            except OSError:
                pass
            for f in d.glob("*.org"):
                try:
                    best = max(best, f.stat().st_mtime)
                except OSError:
                    pass
        return best

    def changed(self) -> bool:
        cur = self._scan()
        if cur != self._last_mtime:
            self._last_mtime = cur
            return True
        return False


def _run(stdscr) -> None:
    curses.curs_set(0)
    if curses.has_colors():
        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(1, curses.COLOR_GREEN, -1)   # agent
        curses.init_pair(2, curses.COLOR_YELLOW, -1)  # user
        curses.init_pair(3, curses.COLOR_RED, -1)     # blocked

    watcher = _Watcher.create()
    stdscr.timeout(_MAIN_LOOP_TIMEOUT_MS)  # getch() returns -1 after this many ms

    # Search state. `search_query` is the current filter substring; when
    # non-empty it filters the row list. `search_active` is True while
    # the user is typing into the query (search mode); when False the
    # query may still be non-empty — that's a "locked" filter, where the
    # normal keymap works on the filtered set.
    search_query = ""
    search_active = False

    groups = load_tasks()
    rows = _flatten(groups, search_query)
    selectables = _selectable_indices(rows)
    selected = selectables[0] if selectables else 0
    status = ""

    def reload(label: str) -> tuple[list, int, str]:
        # Remember which task is highlighted so the highlight can
        # follow it if the rebuilt rows reorder it (stage re-sort, a
        # task inserted above it, an active/ -> completed/ move).
        nonlocal groups
        prev_key = None
        if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
            prev_key = _task_key(rows[selected][1])
        groups = load_tasks()
        new_rows = _flatten(groups, search_query)
        return new_rows, _follow_selection(new_rows, prev_key, selected), label

    def refilter() -> tuple[list, int]:
        # Re-flatten the existing groups with the current query and
        # keep the highlight on the same task when possible.
        prev_key = None
        if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
            prev_key = _task_key(rows[selected][1])
        new_rows = _flatten(groups, search_query)
        return new_rows, _follow_selection(new_rows, prev_key, selected)

    def dashboard_redraw() -> None:
        # Repaints the dashboard at the current rows/selected/status.
        # Used by the modal flows so they can refresh the dashboard
        # underneath their overlay (the modal's win.refresh() paints
        # on top of stdscr afterwards, so this doesn't clobber it).
        _draw(stdscr, rows, selected, display_status)

    while True:
        if search_active:
            display_status = f"/{search_query}"
        elif search_query:
            display_status = (
                f"filter: {search_query}  (Esc to clear, / to refine)"
            )
        else:
            display_status = status
        _draw(stdscr, rows, selected, display_status)
        status = ""
        try:
            ch = stdscr.getch()
        except KeyboardInterrupt:
            return

        if ch == -1:
            # idle tick — auto-reload if anything changed.
            if watcher.changed():
                rows, selected, status = reload("auto-reloaded")
            continue

        if ch == curses.KEY_RESIZE:
            # Terminal was resized; flush curses' cached dimensions and
            # clear stdscr. The next loop iteration's _draw() paints at
            # the new (h, w). Placed before search_active so the search
            # prompt also repaints on resize.
            _handle_resize(stdscr)
            continue

        if search_active:
            # In search-mode typing, every printable byte feeds the
            # query. Only Esc / Enter / Backspace / arrows are control
            # keys.
            if ch == 27:  # Esc: clear and exit search mode
                search_query = ""
                search_active = False
                rows, selected = refilter()
            elif ch in (curses.KEY_ENTER, 10, 13):  # Enter: lock filter
                search_active = False
            elif ch in (curses.KEY_BACKSPACE, 127, 8):
                if search_query:
                    search_query = search_query[:-1]
                    rows, selected = refilter()
            elif ch in (curses.KEY_DOWN,):
                selected = _move_selection(rows, selected, +1)
            elif ch in (curses.KEY_UP,):
                selected = _move_selection(rows, selected, -1)
            elif 32 <= ch < 127:
                search_query += chr(ch)
                rows, selected = refilter()
            # Anything else (function keys, etc.) is ignored.
            continue

        if ch == ord("/"):
            # Start a fresh search; any previously locked filter is
            # cleared so the user types into an empty query.
            search_active = True
            search_query = ""
            rows, selected = refilter()
            continue
        if ch == 27:  # Esc outside search: clear locked filter if any
            if search_query:
                search_query = ""
                rows, selected = refilter()
                continue
            return
        if ch == ord("q"):
            return
        elif ch in (curses.KEY_DOWN, ord("j")):
            selected = _move_selection(rows, selected, +1)
        elif ch in (curses.KEY_UP, ord("k")):
            selected = _move_selection(rows, selected, -1)
        elif ch == ord("g"):
            sels = _selectable_indices(rows)
            if sels:
                selected = sels[0]
        elif ch == ord("G"):
            sels = _selectable_indices(rows)
            if sels:
                selected = sels[-1]
        elif ch == ord("r"):
            rows, selected, status = reload("reloaded")
        elif ch == ord("p"):
            if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
                t: Task = rows[selected][1]  # type: ignore[assignment]
                if t.pr_url:
                    webbrowser.open(t.pr_url)
                    status = f"opened {t.pr_url}"
                else:
                    status = "(no PR)"
        elif ch == ord("t"):
            if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
                t: Task = rows[selected][1]  # type: ignore[assignment]
                status = _switch_tmux(stdscr, t)
        elif ch == ord("c"):
            if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
                t: Task = rows[selected][1]  # type: ignore[assignment]
                # Only ACTIVE/RECENT rows are backed by a per-task
                # YYYY-MM-DD-<slug>.org file; STAGING/TODO rows all
                # share staging.org and have no per-task slug.
                if t.section in (ACTIVE, RECENT):
                    slug = _slug_from_filename(t.path)
                    if _copy_to_clipboard(slug):
                        status = f"copied slug: {slug}"
                    else:
                        status = (
                            "(no clipboard tool: install wl-clipboard, "
                            "xclip, or xsel)"
                        )
                else:
                    status = "(no slug: not a per-task file)"
        elif ch == ord("P"):
            if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
                t: Task = rows[selected][1]  # type: ignore[assignment]
                staging_list: list[Task] = groups[STAGING]  # type: ignore[assignment]
                status = _promote_staging(stdscr, t, staging_list, dashboard_redraw)
                # The new active task will show up via inotify, but
                # nudge a reload anyway so success is reflected
                # immediately even when watchers are absent.
                if status.startswith("promoted: "):
                    rows, selected, _ = reload("reloaded")
                    # Land the highlight on the just-promoted row —
                    # the chain's final step is creating
                    # tasks/active/<date>-<slug>.org, so the ACTIVE
                    # row with the freshest ctime is the new task.
                    new_idx = _newest_active_row_index(rows)
                    if new_idx is not None:
                        selected = new_idx
        elif ch == ord("f"):
            if 0 <= selected < len(rows) and rows[selected][0] == ROW_TASK:
                t: Task = rows[selected][1]  # type: ignore[assignment]
                status = _finalize_task(stdscr, t, dashboard_redraw)


def main() -> int:
    if not TASKS.is_dir():
        sys.stderr.write(f"cloude-dash: tasks dir not found at {TASKS}\n")
        return 1
    os.environ.setdefault("ESCDELAY", "25")
    curses.wrapper(_run)
    return 0


if __name__ == "__main__":
    sys.exit(main())
