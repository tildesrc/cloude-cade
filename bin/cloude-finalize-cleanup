#!/usr/bin/env bash
# Mechanical cleanup chain for /finalize.
#
# Given an active task file whose TODO is COMPLETE or DROPPED,
# this performs the side-effect steps the agent shouldn't have to
# narrate one tool call at a time:
#
#   1. Source cloude-task-info to load metadata.
#   2. Decide action from $TODO and verify/close the PR.
#   3. Kill the tmux session.
#   4. Remove the git worktree.
#   5. Remove the DinD volume (cloude-dind-<slug>).
#   6. (COMPLETE only) delete the local branch.
#   7. Move the task file into tasks/{completed,dropped}/.
#   8. Print a summary block on stdout.
#
# Judgment-call cases bail with distinct exit codes so the calling
# skill can prompt the user and rerun with the matching override:
#
#   10 — TODO=COMPLETE but the PR is accessible and not in state
#        MERGED. Safety guard against a premature COMPLETE flip; not
#        overridable here — fix the task heading and re-run.
#   11 — TODO is neither COMPLETE nor DROPPED. Pass --force-drop to
#        flip the keyword to DROPPED and proceed.
#   12 — Worktree removal failed (dirty / locked). Pass
#        --force-worktree to retry with git's --force.
#   13 — DinD volume removal failed because something is using it.
#        Pass --skip-volume to leave it in place.
#   14 — Worktree contains files owned by another user (e.g. root,
#        from in-container DinD test runs), which the host user can't
#        unlink. Pass --force-root to nuke the dir via a privileged
#        `docker run --user root` step (implies --force-worktree).
#   15 — TODO=COMPLETE but the PR is not accessible at all (gh pr view
#        exited nonzero: repo deleted, auth lost, network failure).
#        Pass --force-pr-absent to proceed with cleanup anyway. For
#        DROPPED / forced-drop, an inaccessible PR is tolerated
#        silently (the close step is skipped).
#
# Idempotency: tmux session, DinD volume, local branch, and worktree
# (both the directory and the source clone's bookkeeping) all tolerate
# being already absent — finalize succeeds on a partially-cleaned-up
# task and reports "absent" in the summary for whichever resource was
# already gone.
#
# Anything else is a hard failure: 20 (gh pr close), 21 (file move),
# 22 (task-info), 23 (heading rewrite), 25 (worktree remove failed
# even with --force-worktree, non-permission reason), 26 (root
# cleanup ran but worktree dir still present afterward),
# 30 (arg validation).

set -euo pipefail

usage() {
    cat <<EOF
Usage: $(basename "$0") <task-file> [options]

Options:
  --force-drop       Treat non-terminal TODO as DROPPED; flip the
                     heading's keyword in place and proceed.
  --force-worktree   Pass --force to 'git worktree remove'.
  --force-root       Nuke a worktree containing files owned by another
                     user (e.g. root, from in-container DinD test runs)
                     via 'docker run --rm --user root … rm -rf'.
                     Implies --force-worktree.
  --force-pr-absent  Proceed even if 'gh pr view' can't reach the PR
                     (COMPLETE-mode only — DROPPED tolerates this
                     silently).
  --skip-volume      Skip DinD volume removal.

Exit codes:
   0  success
  10  PR not MERGED (COMPLETE-mode only; PR is accessible)
  11  TODO not COMPLETE/DROPPED, --force-drop not given
  12  worktree dirty / locked, --force-worktree not given
  13  DinD volume in use, --skip-volume not given
  14  worktree contains foreign-owned files, --force-root not given
  15  PR not accessible (COMPLETE-mode only), --force-pr-absent not given
  20+ other failure (stderr names the step)
  30  argument validation
EOF
}

if [[ $# -lt 1 ]]; then
    usage >&2
    exit 30
fi

TASK_FILE=""
FORCE_DROP=false
FORCE_WORKTREE=false
FORCE_ROOT=false
FORCE_PR_ABSENT=false
SKIP_VOLUME=false

while (($#)); do
    case "$1" in
        --force-drop)      FORCE_DROP=true ;;
        --force-worktree)  FORCE_WORKTREE=true ;;
        --force-root)      FORCE_ROOT=true; FORCE_WORKTREE=true ;;
        --force-pr-absent) FORCE_PR_ABSENT=true ;;
        --skip-volume)     SKIP_VOLUME=true ;;
        -h|--help)         usage; exit 0 ;;
        --)                shift; TASK_FILE="$1" ;;
        -*)                echo "ERROR: unknown flag: $1" >&2; usage >&2; exit 30 ;;
        *)
            if [[ -n "$TASK_FILE" ]]; then
                echo "ERROR: extra positional arg: $1" >&2
                exit 30
            fi
            TASK_FILE="$1"
            ;;
    esac
    shift
done

if [[ -z "$TASK_FILE" || ! -f "$TASK_FILE" ]]; then
    echo "ERROR: task file not found: $TASK_FILE" >&2
    exit 30
fi
TASK_FILE="$(cd "$(dirname "$TASK_FILE")" && pwd)/$(basename "$TASK_FILE")"

# Resolve sibling helpers from this script's directory.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TASK_INFO="$SCRIPT_DIR/cloude-task-info"
SET_STATE="$SCRIPT_DIR/cloude-task-set-state"
if [[ ! -x "$TASK_INFO" ]]; then
    echo "ERROR: cloude-task-info not found alongside this script: $TASK_INFO" >&2
    exit 22
fi

# Load metadata. cloude-task-info emits shlex-quoted KEY=VALUE lines.
info_out="$("$TASK_INFO" "$TASK_FILE")" || {
    echo "ERROR: cloude-task-info failed (exit $?). See its stderr above." >&2
    exit 22
}
eval "$info_out"

# $TODO $TAG $HEADING $WORKTREE $BRANCH $PR $REPO $ID
# $ADOPTED $COMPANION
# $SLUG $REPO_NAME $SOURCE_CLONE $TMUX_SESSION $DIND_VOLUME $CLOUDE_ROOT

# --- Step 2: decide action from $TODO --------------------------------------
#
# PR handling has two independent signals:
#   - "accessible": did 'gh pr view' return at all?
#   - "state":      the .state field (only meaningful when accessible).
#
# COMPLETE requires accessible && state=MERGED — accessible-but-unmerged
# is a safety guard (exit 10, not overridable here), inaccessible is the
# --force-pr-absent override (exit 15). DROPPED / forced-drop tolerate
# inaccessible silently (the close step is just skipped).

# Sets globals pr_accessible (true/false) and pr_state (state string when
# accessible, empty otherwise). The 'if assign; then' shape keeps set -e
# from tripping on gh's nonzero exit.
probe_pr_state() {
    if pr_state="$(gh pr view "$PR" --json state -q .state 2>/dev/null)"; then
        pr_accessible=true
    else
        pr_accessible=false
        pr_state=""
    fi
}

# Close the PR if it's accessible and OPEN; record the outcome in
# PR_RESULT for the summary block. Shared between the DROPPED case and
# the forced-drop branch — the close-if-OPEN logic is identical.
maybe_close_pr_for_drop() {
    if ! $pr_accessible; then
        PR_RESULT="not accessible"
        return
    fi
    if [[ "$pr_state" == "OPEN" ]]; then
        if ! gh pr close "$PR" --delete-branch=false >/dev/null; then
            echo "ERROR: gh pr close failed for $PR" >&2
            exit 20
        fi
        PR_RESULT="closed"
    else
        # Already CLOSED / MERGED — nothing to do, just label it.
        PR_RESULT="already ${pr_state,,}"
    fi
}

FORCED_DROP=false
PR_RESULT=""
pr_accessible=false
pr_state=""

case "$TODO" in
    COMPLETE)
        probe_pr_state
        if $pr_accessible; then
            if [[ "$pr_state" != "MERGED" ]]; then
                echo "ERROR: task is COMPLETE but PR is in state: $pr_state" >&2
                echo "       fix: set the TODO back to MERGING in $TASK_FILE and re-run" >&2
                echo "       once the merge actually lands." >&2
                exit 10
            fi
            PR_RESULT="confirmed MERGED"
        elif $FORCE_PR_ABSENT; then
            PR_RESULT="not accessible (forced)"
        else
            echo "ERROR: 'gh pr view $PR' failed — PR is not accessible" >&2
            echo "       (repo deleted, auth lost, or network failure)." >&2
            echo "       pass --force-pr-absent to proceed with cleanup anyway." >&2
            exit 15
        fi
        ;;
    DROPPED)
        probe_pr_state
        maybe_close_pr_for_drop
        ;;
    *)
        if ! $FORCE_DROP; then
            echo "ERROR: task TODO is '$TODO', not COMPLETE or DROPPED." >&2
            echo "       pass --force-drop to flip to DROPPED and proceed." >&2
            exit 11
        fi
        # Flip the TODO keyword on the heading to DROPPED, in place,
        # via the shared heading-rewriter (the org parsing lives there,
        # not re-derived here). The tag is left as-is.
        if [[ ! -x "$SET_STATE" ]]; then
            echo "ERROR: cloude-task-set-state not found alongside this script: $SET_STATE" >&2
            exit 23
        fi
        if ! "$SET_STATE" "$TASK_FILE" --todo DROPPED >/dev/null; then
            echo "ERROR: failed to flip TODO keyword to DROPPED in $TASK_FILE" >&2
            exit 23
        fi
        TODO=DROPPED
        FORCED_DROP=true
        probe_pr_state
        maybe_close_pr_for_drop
        ;;
esac

# --- Step 3: kill tmux session ---------------------------------------------

TMUX_KILLED=false
if tmux has-session -t "=$TMUX_SESSION" 2>/dev/null; then
    tmux kill-session -t "$TMUX_SESSION" 2>/dev/null || true
    TMUX_KILLED=true
fi

# --- Step 4: remove worktree -----------------------------------------------
#
# Tier 0: if both the worktree dir AND the source clone's bookkeeping
#         entry are gone, the worktree was already cleaned up
#         (externally, or by a previous partial run). Skip — idempotent.
#         (Note: "dir gone, bookkeeping present" doesn't need a special
#         case; 'git worktree remove' silently prunes that one.)
# Tier 1: 'git worktree remove [--force]' as usual.
# Tier 2: on failure, if the worktree contains foreign-owned files
#         (e.g. root, written by in-container DinD test runs), this
#         is the --force-root case — either bail with exit 14, or
#         nuke via 'docker run --rm --user root … rm -rf'.
# Tier 3: on failure with no foreign-owned files, fall back to the
#         existing exit 12 (no --force-worktree) / 25 (had --force-
#         worktree, still failed for some other reason) paths.

# True iff $SOURCE_CLONE has a 'git worktree list' entry for $WORKTREE.
# Used by the Tier-0 absent-check; the dir-on-disk check is the other
# half. Returns 1 if the source clone itself is missing — paired with
# '! -d "$WORKTREE"' this is exactly the fully-absent signal.
worktree_registered() {
    [[ -d "$SOURCE_CLONE" ]] || return 1
    git -C "$SOURCE_CLONE" worktree list --porcelain 2>/dev/null \
        | awk -v p="$WORKTREE" '
            /^worktree / { if ($2 == p) { found = 1; exit } }
            END { exit !found }
        '
}

remove_worktree() {
    local extra=()
    if $FORCE_WORKTREE; then
        extra+=(--force)
    fi
    git -C "$SOURCE_CLONE" worktree remove "${extra[@]}" "$WORKTREE"
}

# Count files under $WORKTREE not owned by the running user. Suppresses
# the noisy "Permission denied" find prints because the host user may
# legitimately be unable to descend into root-owned dirs — for our
# purposes, the dir entry itself is already evidence enough. find then
# exits nonzero on those denied descents; under this script's
# 'set -euo pipefail' that would propagate through the pipe and abort
# the calling 'foreign="$(foreign_owned_count)"' command substitution
# before --force-root could even be consulted. '|| true' swallows
# find's exit so wc -l still reports the rows it printed.
foreign_owned_count() {
    [[ -d "$WORKTREE" ]] || { echo 0; return; }
    { find "$WORKTREE" -not -user "$(id -un)" 2>/dev/null || true; } | wc -l
}

# Docker-as-root rm of the worktree directory. Mounts the parent dir
# so 'rm -rf' can remove the slug dir itself (you can't unlink the
# mount point from inside the container).
nuke_worktree_as_root() {
    local parent slug
    parent="$(dirname "$WORKTREE")"
    slug="$(basename "$WORKTREE")"
    docker run --rm --user root --entrypoint /bin/bash \
        -v "$parent":/wt:rw \
        cloude -c "rm -rf -- /wt/$(printf %q "$slug")"
}

ROOT_CLEANED=false
WORKTREE_ABSENT=false
if [[ ! -d "$WORKTREE" ]] && ! worktree_registered; then
    # Tier 0: nothing for git or rm to do — already cleaned up.
    WORKTREE_ABSENT=true
elif ! err="$(remove_worktree 2>&1)"; then
    foreign="$(foreign_owned_count)"
    if (( foreign > 0 )); then
        # Tier 2: foreign-owned files (typically root, from DinD).
        if ! $FORCE_ROOT; then
            echo "ERROR: worktree contains $foreign file(s) not owned by $(id -un):" >&2
            echo "$err" >&2
            echo "       these are typically root-owned artifacts written by an" >&2
            echo "       in-container DinD test stack (e.g. coverage/, tmp/minio/," >&2
            echo "       tmp/dbdata/). The host user can't unlink them." >&2
            echo "       pass --force-root to nuke via 'docker run --user root'" >&2
            echo "       (implies --force-worktree)." >&2
            exit 14
        fi
        echo "Worktree has $foreign foreign-owned file(s); running root cleanup…" >&2
        if ! nuke_worktree_as_root >&2; then
            echo "ERROR: 'docker run --user root … rm -rf' failed for $WORKTREE" >&2
            exit 26
        fi
        # Clear stale .git/worktrees/<name>/ bookkeeping that git
        # would otherwise leave behind once the dir is gone.
        git -C "$SOURCE_CLONE" worktree prune >&2 || true
        if [[ -d "$WORKTREE" ]]; then
            echo "ERROR: root cleanup ran but $WORKTREE still exists" >&2
            exit 26
        fi
        ROOT_CLEANED=true
    elif $FORCE_WORKTREE; then
        # Tier 3a: --force was given, no foreign-owned files — some
        # other failure (locked, etc.). Hard fail.
        echo "ERROR: worktree removal failed even with --force-worktree:" >&2
        echo "$err" >&2
        exit 25
    else
        # Tier 3b: dirty/locked, no --force-worktree.
        echo "ERROR: worktree removal failed (dirty / locked / untracked files):" >&2
        echo "$err" >&2
        if [[ -d "$WORKTREE" ]]; then
            echo "--- git status --short ---" >&2
            git -C "$WORKTREE" status --short >&2 || true
        fi
        echo "       pass --force-worktree to discard and retry." >&2
        exit 12
    fi
fi

if $WORKTREE_ABSENT; then
    WORKTREE_RESULT="absent"
elif $ROOT_CLEANED; then
    WORKTREE_RESULT="removed (forced; root cleanup)"
elif $FORCE_WORKTREE; then
    WORKTREE_RESULT="removed (forced)"
else
    WORKTREE_RESULT="removed"
fi

# --- Step 5: remove DinD volume --------------------------------------------

VOLUME_REMOVED="skipped"
if ! $SKIP_VOLUME; then
    if docker volume inspect "$DIND_VOLUME" >/dev/null 2>&1; then
        if err="$(docker volume rm "$DIND_VOLUME" 2>&1)"; then
            VOLUME_REMOVED="yes"
        else
            echo "ERROR: docker volume rm failed for $DIND_VOLUME:" >&2
            echo "$err" >&2
            echo "--- containers using this volume ---" >&2
            docker ps -a --filter "volume=$DIND_VOLUME" >&2 || true
            echo "       pass --skip-volume to leave it in place." >&2
            exit 13
        fi
    else
        VOLUME_REMOVED="absent"
    fi
fi

# --- Step 6: delete local branch (COMPLETE only) ---------------------------

BRANCH_RESULT="preserved (DROPPED)"
if [[ "$TODO" == "COMPLETE" ]]; then
    if git -C "$SOURCE_CLONE" branch -D "$BRANCH" >/dev/null 2>&1; then
        BRANCH_RESULT="deleted"
    else
        BRANCH_RESULT="not present"
    fi
fi

# --- Step 7: move the task file --------------------------------------------

if [[ "$TODO" == "COMPLETE" ]]; then
    DEST_DIR="$CLOUDE_ROOT/tasks/completed"
else
    DEST_DIR="$CLOUDE_ROOT/tasks/dropped"
fi
mkdir -p "$DEST_DIR"
DEST="$DEST_DIR/$(basename "$TASK_FILE")"
if ! mv "$TASK_FILE" "$DEST"; then
    echo "ERROR: failed to move $TASK_FILE → $DEST" >&2
    exit 21
fi

# --- Step 8: summary -------------------------------------------------------

cat <<EOF
Final state: $TODO$( $FORCED_DROP && echo " (force-dropped from previous state)" )
Task file: moved → $DEST
tmux session $TMUX_SESSION: $( $TMUX_KILLED && echo killed || echo "was not running" )
Worktree $WORKTREE: $WORKTREE_RESULT
DinD volume $DIND_VOLUME: $VOLUME_REMOVED
Local branch $BRANCH: $BRANCH_RESULT
PR $PR: $PR_RESULT
EOF
